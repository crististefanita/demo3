+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.MessagesPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+import java.util.List;
+
+public final class MessagesService {
+
+    public void openMessages() {
+        UIActions.navigateToRelative("/account/messages");
+        WaitUtils.waitForVisible(MessagesPage.BODY);
+    }
+
+    public void openFirstMessageDetails() {
+        UIActions.click(MessagesPage.FIRST_DETAILS, "First message details");
+        WaitUtils.waitForCondition(
+                "message details route is visible",
+                () -> DriverManager.getEngine().getCurrentUrl().contains("/account/messages/"),
+                "Expected message details route to be visible after opening row details."
+        );
+        WaitUtils.waitForVisible(MessagesPage.DETAIL_STATUS);
+    }
+
+    public void waitForMessageRow(String expectedFragment) {
+        WaitUtils.waitForCondition(
+                "message row is visible in account messages",
+                () -> {
+                    String body = DriverManager.getEngine().getText(MessagesPage.BODY);
+                    return body != null && body.contains(expectedFragment);
+                },
+                "Expected account messages to contain fragment: " + expectedFragment
+        );
+    }
+
+    public String pageText() {
+        return UIActions.getText(MessagesPage.BODY, "Messages page body");
+    }
+
+    public String firstSubject() {
+        return UIActions.getText(MessagesPage.FIRST_SUBJECT, "First message subject");
+    }
+
+    public String firstMessageSnippet() {
+        return UIActions.getText(MessagesPage.FIRST_MESSAGE, "First message snippet");
+    }
+
+    public String firstStatus() {
+        return UIActions.getText(MessagesPage.FIRST_STATUS, "First message status");
+    }
+
+    public String firstDate() {
+        return UIActions.getText(MessagesPage.FIRST_DATE, "First message date");
+    }
+
+    public int rowCount() {
+        List<String> rows = UIActions.getVisibleTexts(MessagesPage.ROWS, "Message rows");
+        return rows.size();
+    }
+
+    public String currentUrl() {
+        return DriverManager.getEngine().getCurrentUrl();
+    }
+
+    public String detailStatus() {
+        WaitUtils.waitForVisible(MessagesPage.DETAIL_STATUS);
+        return UIActions.getText(MessagesPage.DETAIL_STATUS, "Message detail status");
+    }
+
+    public String detailText() {
+        return UIActions.getText(MessagesPage.BODY, "Message detail body");
+    }
+
+    public void waitForReplySurface() {
+        WaitUtils.waitForVisible(MessagesPage.DETAIL_REPLY_BOX);
+        WaitUtils.waitForVisible(MessagesPage.DETAIL_REPLY_BUTTON);
+    }
+}
