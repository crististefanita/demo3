+package com.endava.ai.atf.ui.commerce;
+
+import org.testng.Assert;
+import org.testng.annotations.Test;
+
+public class CustomerMessageDetailOwnershipTests extends CustomerSupportMessageUiTestBase {
+
+    @Test
+    public void message_details_route_has_persistent_identifier() {
+        submitMessage("Customer service", uniqueMessage("Details identifier probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+
+        Assert.assertTrue(messages.currentUrl().matches(".*/account/messages/[A-Za-z0-9]+$"),
+                "Message details route should expose a persistent message identifier but was: " + messages.currentUrl());
+    }
+
+    @Test
+    public void message_details_preserve_full_message_body() {
+        String message = submitMessage("Return", uniqueMessage("Details body probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+
+        validation.assertPageTextContains(messages.detailText(), message);
+    }
+
+    @Test
+    public void message_details_preserve_new_status_badge() {
+        submitMessage("Payments", uniqueMessage("Details status probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+
+        validation.assertPageTextContains(messages.detailStatus(), "NEW");
+    }
+
+    @Test
+    public void message_details_preserve_customer_subject_context() {
+        submitMessage("Warranty", uniqueMessage("Details subject probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+
+        validation.assertPageTextContains(messages.detailText(), "warranty");
+    }
+
+    @Test
+    public void message_details_expose_reply_surface_for_same_thread() {
+        submitMessage("Status of my order", uniqueMessage("Reply surface probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+        messages.waitForReplySurface();
+
+        validation.assertPageTextContains(messages.detailText(), "Replies");
+    }
+}
