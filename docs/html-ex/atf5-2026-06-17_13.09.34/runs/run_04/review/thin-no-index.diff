+package com.endava.ai.atf.ui.commerce;
+
+import com.endava.ai.ui.utils.UIActions;
+import org.testng.annotations.Test;
+
+public class CustomerMessageReopenabilityOwnershipTests extends CustomerSupportMessageUiTestBase {
+
+    @Test
+    public void message_row_reopens_after_sign_out_and_sign_in() {
+        String message = submitMessage("Customer service", uniqueMessage("Reopen after relogin probe"));
+
+        account.signOut();
+        account.login(customer);
+        messages.openMessages();
+        messages.waitForMessageRow(message.substring(0, 24));
+
+        validation.assertPageTextContains(messages.pageText(), "customer-service");
+    }
+
+    @Test
+    public void message_details_reopen_after_sign_out_and_sign_in() {
+        String message = submitMessage("Return", uniqueMessage("Detail reopen after relogin probe"));
+
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+        account.signOut();
+        account.login(customer);
+        messages.openMessages();
+        messages.openFirstMessageDetails();
+
+        validation.assertPageTextContains(messages.detailText(), message);
+    }
+
+    @Test
+    public void direct_messages_route_reopens_persisted_thread() {
+        String message = submitMessage("Payments", uniqueMessage("Direct route reopen probe"));
+
+        UIActions.navigateToRelative("/");
+        messages.openMessages();
+        messages.waitForMessageRow(message.substring(0, 24));
+
+        validation.assertPageTextContains(messages.pageText(), "payments");
+    }
+
+    @Test
+    public void persisted_message_row_survives_account_route_switch() {
+        String message = submitMessage("Warranty", uniqueMessage("Account route switch probe"));
+
+        account.openProfile();
+        account.openMessages();
+        messages.waitForMessageRow(message.substring(0, 24));
+
+        validation.assertPageTextContains(messages.pageText(), "warranty");
+    }
+
+    @Test
+    public void persisted_message_thread_reopens_from_collection_details() {
+        String message = submitMessage("Status of my order", uniqueMessage("Collection details reopen probe"));
+
+        messages.openMessages();
+        messages.waitForMessageRow(message.substring(0, 24));
+        messages.openFirstMessageDetails();
+
+        validation.assertPageTextContains(messages.detailText(), message);
+    }
+}
