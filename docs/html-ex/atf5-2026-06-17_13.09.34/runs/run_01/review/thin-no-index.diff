+package com.endava.ai.atf.ui.commerce;
+
+import org.testng.annotations.Test;
+
+public class CustomerMessageSubmissionOwnershipTests extends CustomerSupportMessageUiTestBase {
+
+    @Test
+    public void customer_service_message_creates_account_message_row() {
+        String message = submitMessage("Customer service", uniqueMessage("Customer service ownership probe"));
+
+        messages.openMessages();
+        messages.waitForMessageRow(message.substring(0, 24));
+
+        validation.assertPageTextContains(messages.pageText(), "customer-service");
+    }
