@@ -0,0 +1,47 @@
+package com.endava.ai.atf.ui.commerce;
+
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.ContactService;
+import com.endava.ai.ui.service.MessagesService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import com.endava.ai.ui.validation.CommerceValidation;
+import org.testng.annotations.BeforeMethod;
+
+public abstract class CustomerSupportMessageUiTestBase extends BaseTestUI {
+
+    protected final AccountService account = new AccountService();
+    protected final ContactService contact = new ContactService();
+    protected final MessagesService messages = new MessagesService();
+    protected final CommerceValidation validation = new CommerceValidation();
+
+    protected CustomerData customer;
+
+    @BeforeMethod(alwaysRun = true)
+    public void registerAndLoginFreshCustomer() {
+        try {
+            UIActions.clearSession();
+        } catch (Throwable ignored) {
+            // First test can start before a live page exists.
+        }
+        customer = account.registerAndLoginCustomer();
+        validation.assertUrlContains("/account");
+    }
+
+    protected String submitMessage(String subject, String message) {
+        UIActions.navigateToRelative("/contact");
+        WaitUtils.waitForVisible(com.endava.ai.ui.pages.ContactPage.SUBJECT);
+        contact.fillMessage(subject, message);
+        contact.submit();
+        WaitUtils.waitForVisible(com.endava.ai.ui.pages.ContactPage.SUCCESS);
+        validation.assertPageTextContains(UIActions.getText("body", "Contact body"), "Thanks for your message");
+        return message;
+    }
+
+    protected String uniqueMessage(String prefix) {
+        return prefix + " " + System.currentTimeMillis()
+                + " asking for help choosing the correct tool for a repair project today.";
+    }
+}
