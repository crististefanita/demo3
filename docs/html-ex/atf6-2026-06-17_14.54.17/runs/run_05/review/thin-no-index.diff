+package com.endava.ai.ui.tests.checkout.postpurchase;
+
+import com.endava.ai.ui.model.CustomerData;
+import org.testng.annotations.Test;
+
+public class PostPurchaseOrderRowReloginTests extends AbstractPostPurchaseOwnershipTest {
+
+    @Test(description = "Order row still does not materialize through account overview after checkout and relogin")
+    public void order_row_still_does_not_materialize_through_account_overview_after_checkout_and_relogin() {
+        completeCashOnDeliveryCheckoutAndRelogin(1);
+
+        accountService.openOverviewDirect();
+        accountValidation.assertOverviewMentionsOrdersWithoutDedicatedOrdersNavigation();
+    }
+
+    @Test(description = "Direct orders route still fails to materialize an order row after checkout and relogin")
+    public void direct_orders_route_still_fails_to_materialize_an_order_row_after_checkout_and_relogin() {
+        completeCashOnDeliveryCheckoutAndRelogin(1);
+
+        accountService.openOrdersDirect();
+        accountValidation.assertOrdersRouteFallsBackToStorefront();
+    }
+
+    @Test(description = "Two-unit checkout still leaves no order row after relogin")
+    public void two_unit_checkout_still_leaves_no_order_row_after_relogin() {
+        completeCashOnDeliveryCheckoutAndRelogin(2);
+
+        accountService.openOrdersDirect();
+        accountValidation.assertOrdersRouteFallsBackToStorefront();
+    }
+
+    @Test(description = "Double relogin still does not reopen an order row after successful checkout")
+    public void double_relogin_still_does_not_reopen_an_order_row_after_successful_checkout() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+        relogin(customer);
+
+        accountService.openOrdersDirect();
+        accountValidation.assertOrdersRouteFallsBackToStorefront();
+    }
+
+    @Test(description = "Profile identity can reopen after checkout while order history still fails to materialize")
+    public void profile_identity_can_reopen_after_checkout_while_order_history_still_fails_to_materialize() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+
+        accountService.openProfileDirect();
+        accountValidation.assertProfileMatches(customer);
+
+        accountService.openOrdersDirect();
+        accountValidation.assertOrdersRouteFallsBackToStorefront();
+    }
+}


