+package com.endava.ai.ui.tests.checkout.postpurchase;
+
+import com.endava.ai.ui.model.CustomerData;
+import org.testng.annotations.Test;
+
+public class PostPurchaseInvoiceReloginTests extends AbstractPostPurchaseOwnershipTest {
+
+    @Test(description = "Invoice gap survives a cold relogin after checkout success")
+    public void invoice_gap_survives_cold_relogin_after_checkout_success() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Account overview remains reachable after checkout and relogin")
+    public void account_overview_remains_reachable_after_checkout_and_relogin() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+        accountService.openOverviewDirect();
+        accountValidation.assertOverviewExposesAccountManagement();
+    }
+
+    @Test(description = "Invoice ledger remains empty after two relogins")
+    public void invoice_ledger_remains_empty_after_two_relogins() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+        relogin(customer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Profile identity survives checkout before invoice gap inspection")
+    public void profile_identity_survives_checkout_before_invoice_gap_inspection() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        accountService.openProfileDirect();
+        accountValidation.assertProfileMatches(customer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Invoice gap survives relogin after a two-unit checkout")
+    public void invoice_gap_survives_relogin_after_two_unit_checkout() {
+        CustomerData customer = completeCashOnDeliveryCheckout(2);
+        relogin(customer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+}


