+package com.endava.ai.ui.tests.checkout.postpurchase;
+
+import com.endava.ai.ui.model.CustomerData;
+import org.testng.annotations.Test;
+
+public class PostPurchaseInvoiceCustomerBoundaryTests extends AbstractPostPurchaseOwnershipTest {
+
+    @Test(description = "First customer checkout leaves first customer invoice ledger empty")
+    public void first_customer_checkout_leaves_first_customer_invoice_ledger_empty() {
+        assertInvoiceLedgerEmptyAfterSuccessfulCheckout(1);
+    }
+
+    @Test(description = "Second customer starts with an empty invoice ledger")
+    public void second_customer_starts_with_empty_invoice_ledger() {
+        CustomerData firstCustomer = completeCashOnDeliveryCheckout(1);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+
+        CustomerData secondCustomer = registerAndLoginCustomer();
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesExposeLedgerSurface();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+
+        relogin(firstCustomer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Two independent customers keep separate empty invoice ledgers after checkout")
+    public void two_independent_customers_keep_separate_empty_invoice_ledgers_after_checkout() {
+        CustomerData firstCustomer = completeCashOnDeliveryCheckout(1);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+
+        CustomerData secondCustomer = completeCashOnDeliveryCheckout(1);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+
+        relogin(firstCustomer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+
+        relogin(secondCustomer);
+        accountService.openOverviewDirect();
+        accountValidation.assertOverviewExposesAccountManagement();
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Customer invoice gap remains scoped to the authenticated account after relogin")
+    public void customer_invoice_gap_remains_scoped_after_relogin() {
+        CustomerData customer = completeCashOnDeliveryCheckout(1);
+        relogin(customer);
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+
+    @Test(description = "Fresh registered customer does not inherit another checkout invoice")
+    public void fresh_registered_customer_does_not_inherit_another_checkout_invoice() {
+        completeCashOnDeliveryCheckout(1);
+        registerAndLoginCustomer();
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+    }
+}


