+package com.endava.ai.ui.tests.checkout.postpurchase;
+
+import com.endava.ai.ui.model.CustomerData;
+import org.testng.annotations.Test;
+
+public class PostPurchaseReceiptIdentityGapTests extends AbstractPostPurchaseOwnershipTest {
+
+    @Test(description = "Payment success message does not expose a reopenable order identity on the success screen")
+    public void payment_success_message_does_not_expose_a_reopenable_order_identity_on_the_success_screen() {
+        completeCashOnDeliveryCheckout(1);
+
+        assertCheckoutSuccessLacksReceiptIdentity();
+    }
+
+    @Test(description = "Payment success does not expose a reopenable invoice identity on the success screen")
+    public void payment_success_does_not_expose_a_reopenable_invoice_identity_on_the_success_screen() {
+        completeCashOnDeliveryCheckout(1);
+
+        assertCheckoutSuccessLacksReceiptIdentity();
+    }
+
+    @Test(description = "Relogin clears the payment success message without reopening any order identity")
+    public void relogin_clears_the_payment_success_message_without_reopening_any_order_identity() {
+        completeCashOnDeliveryCheckoutAndRelogin(1);
+
+        accountService.openOverviewDirect();
+        assertAccountReopenLacksReceiptIdentity();
+    }
+
+    @Test(description = "Invoice ledger can reopen after relogin but still exposes no row that can anchor the payment confirmation")
+    public void invoice_ledger_can_reopen_after_relogin_but_still_exposes_no_row_that_can_anchor_the_payment_confirmation() {
+        completeCashOnDeliveryCheckoutAndRelogin(1);
+
+        accountService.openInvoicesDirect();
+        accountValidation.assertInvoicesLedgerRemainsEmptyAfterCheckoutSuccess();
+        assertReopenedInvoicesLackReceiptIdentity();
+    }
+
+    @Test(description = "Two-unit checkout still leaves the payment confirmation without a reopenable receipt identity")
+    public void two_unit_checkout_still_leaves_the_payment_confirmation_without_a_reopenable_receipt_identity() {
+        CustomerData customer = completeCashOnDeliveryCheckout(2);
+        assertCheckoutSuccessLacksReceiptIdentity();
+
+        relogin(customer);
+        accountService.openOverviewDirect();
+        assertAccountReopenLacksReceiptIdentity();
+    }
+}


