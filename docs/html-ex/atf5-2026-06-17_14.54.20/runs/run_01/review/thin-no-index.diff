+package com.endava.ai.atf.ui.commerce;
+
+import org.testng.annotations.Test;
+
+public class GuestPostPaymentOwnershipBoundaryTests extends CommerceUiTestBase {
+
+    @Test
+    public void successful_payment_does_not_surface_order_number_for_guest() {
+        openGuestPaymentSuccess();
+
+        validation.assertPageTextDoesNotContain(cart.pageText(), "order number");
+    }
+
+    @Test
+    public void successful_payment_does_not_surface_invoice_for_guest() {
+        openGuestPaymentSuccess();
+
+        validation.assertPageTextDoesNotContain(cart.pageText(), "invoice");
+    }
+
+    @Test
+    public void successful_payment_does_not_surface_downloadable_receipt_for_guest() {
+        openGuestPaymentSuccess();
+
+        validation.assertPageTextDoesNotContain(cart.pageText(), "receipt");
+    }
+
+    @Test
+    public void successful_payment_does_not_surface_order_history_for_guest() {
+        openGuestPaymentSuccess();
+
+        validation.assertPageTextDoesNotContain(cart.pageText(), "order history");
+    }
+
+    @Test
+    public void successful_payment_still_exposes_sign_in_instead_of_guest_ownership_area() {
+        openGuestPaymentSuccess();
+
+        validation.assertPageTextContains(cart.pageText(), "Sign in");
+    }
