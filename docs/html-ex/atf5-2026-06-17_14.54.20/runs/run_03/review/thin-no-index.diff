+package com.endava.ai.atf.ui.commerce;
+
+import org.testng.annotations.Test;
+
+public class GuestInvoiceReceiptOwnershipProbeTests extends CommerceUiTestBase {
+
+    @Test
+    public void guest_payment_success_has_no_invoice_label() {
+        openGuestPaymentSuccess();
+
+        assertPaymentSuccessWithout("invoice");
+    }
+
+    @Test
+    public void guest_payment_success_has_no_receipt_label() {
+        openGuestPaymentSuccess();
+
+        assertPaymentSuccessWithout("receipt");
+    }
+
+    @Test
+    public void guest_payment_success_has_no_download_invoice_action() {
+        openGuestPaymentSuccess();
+
+        assertPaymentSuccessWithout("download invoice");
+    }
+
+    @Test
+    public void guest_payment_success_has_no_tax_document_label() {
+        openGuestPaymentSuccess();
+
+        assertPaymentSuccessWithout("tax invoice");
+    }
+
+    @Test
+    public void guest_payment_success_has_no_printable_purchase_document() {
+        openGuestPaymentSuccess();
+
+        assertPaymentSuccessWithout("print receipt");
+    }
+
+    private void assertPaymentSuccessWithout(String forbidden) {
+        validation.assertPageTextContains(cart.pageText(), "Payment was successful");
+        validation.assertPageTextDoesNotContain(cart.pageText(), forbidden);
+    }
+}
