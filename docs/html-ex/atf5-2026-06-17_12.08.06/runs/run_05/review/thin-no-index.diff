+package com.endava.ai.atf.ui.customer;
+
+import com.endava.ai.ui.service.CatalogService;
+import com.endava.ai.ui.service.ProductService;
+import org.testng.Assert;
+import org.testng.annotations.Test;
+
+import java.util.List;
+
+public class CustomerFavoriteCollectionIntegrityTests extends AccountCustomerUiTestBase {
+
+    private final CatalogService catalog = new CatalogService();
+    private final ProductService product = new ProductService();
+
+    @Test
+    public void repeated_add_keeps_one_owned_favorite_object_not_fake_breadth() {
+        account.registerAndLoginCustomer();
+
+        catalog.openHome();
+        catalog.openFirstProduct();
+        String expectedProduct = product.name();
+        product.addToFavorites();
+        product.addToFavorites();
+
+        account.openFavorites();
+        account.waitForFavoriteProduct(expectedProduct);
+
+        Assert.assertEquals(account.favoriteProductCount(), 1,
+                "Repeated add should keep one favorite row for the same product.");
+    }
+
+    @Test
+    public void related_product_navigation_does_not_fake_second_favorite_row() {
+        account.registerAndLoginCustomer();
+
+        catalog.openHome();
+        catalog.openFirstProduct();
+        String firstProduct = product.name();
+        product.addToFavorites();
+        product.openFirstRelatedProduct();
+        String secondProduct = product.name();
+        product.addToFavorites();
+
+        account.openFavorites();
+        account.waitForFavoriteProduct(secondProduct);
+
+        Assert.assertEquals(firstProduct, secondProduct,
+                "Current related-product navigation reopens the same product identity in this app.");
+        Assert.assertEquals(account.favoriteProductCount(), 1,
+                "Same-product revisit must not be sold as a second owned favorite row.");
+    }
+
+    @Test
+    public void favorites_names_include_both_added_products() {
+        account.registerAndLoginCustomer();
+
+        catalog.openHome();
+        catalog.openFirstProduct();
+        String firstProduct = product.name();
+        product.addToFavorites();
+        product.openFirstRelatedProduct();
+        String secondProduct = product.name();
+        product.addToFavorites();
+
+        account.openFavorites();
+        account.waitForFavoriteProduct(secondProduct);
+
+        List<String> favoriteNames = account.favoriteProductNames();
+        Assert.assertTrue(favoriteNames.contains(firstProduct), "Favorites should include the first product identity.");
+        Assert.assertTrue(favoriteNames.contains(secondProduct), "Favorites should include the second product identity.");
+    }
+
+    @Test
+    public void favorites_collection_does_not_claim_empty_state_after_two_rows() {
+        account.registerAndLoginCustomer();
+
+        catalog.openHome();
+        catalog.openFirstProduct();
+        product.addToFavorites();
+        product.openFirstRelatedProduct();
+        product.addToFavorites();
+
+        account.openFavorites();
+        account.waitForFavoriteProduct(product.name());
+
+        validation.assertPageTextDoesNotContain(account.pageText(), "There are no favorites yet");
+    }
+
+    @Test
+    public void second_favorite_addition_preserves_first_product_identity() {
+        account.registerAndLoginCustomer();
+
+        catalog.openHome();
+        catalog.openFirstProduct();
+        String firstProduct = product.name();
+        product.addToFavorites();
+        product.openFirstRelatedProduct();
+        product.addToFavorites();
+
+        account.openFavorites();
+        account.waitForFavoriteProduct(firstProduct);
+
+        Assert.assertTrue(account.favoriteProductNames().contains(firstProduct),
+                "Adding a second favorite must not erase the first owned favorite row.");
+    }
+}

