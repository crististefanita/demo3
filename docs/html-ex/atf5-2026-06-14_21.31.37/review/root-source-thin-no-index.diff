@@ -0,0 +1,92 @@
+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.ProfilePage;
+import com.endava.ai.ui.utils.TotpGenerator;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+import java.time.Duration;
+import java.util.List;
+import java.util.regex.Matcher;
+import java.util.regex.Pattern;
+
+public final class ProfileService {
+
+    private static final Pattern TOTP_SECRET_PATTERN = Pattern.compile("\\b[A-Z2-7]{16,}\\b");
+
+    public void openProfile() {
+        UIActions.navigateToRelative("/account/profile");
+        WaitUtils.waitForVisible(ProfilePage.PAGE_ROOT);
+        WaitUtils.waitForVisible(ProfilePage.FIRST_NAME);
+    }
+
+    public void changePassword(String currentPassword, String newPassword) {
+        changePassword(currentPassword, newPassword, newPassword);
+    }
+
+    public void changePassword(String currentPassword, String newPassword, String confirmedPassword) {
+        UIActions.type(ProfilePage.CURRENT_PASSWORD, "Current password", currentPassword);
+        UIActions.type(ProfilePage.NEW_PASSWORD, "New password", newPassword);
+        UIActions.type(ProfilePage.NEW_PASSWORD_CONFIRM, "Confirm new password", confirmedPassword);
+        UIActions.click(ProfilePage.CHANGE_PASSWORD_BUTTON, "Change password");
+        WaitUtils.pause(Duration.ofSeconds(2));
+    }
+
+    public void submitEmptyTotpSetupCode() {
+        WaitUtils.waitForVisible(ProfilePage.TOTP_CODE);
+        UIActions.click(ProfilePage.VERIFY_TOTP_BUTTON, "Verify TOTP");
+    }
+
+    public void submitTotpSetupCode(String code) {
+        WaitUtils.waitForVisible(ProfilePage.TOTP_CODE);
+        UIActions.type(ProfilePage.TOTP_CODE, "TOTP setup code", code);
+        UIActions.click(ProfilePage.VERIFY_TOTP_BUTTON, "Verify TOTP");
+    }
+
+    public String enableTotp() {
+        WaitUtils.waitForVisible(ProfilePage.TOTP_CODE);
+        String secret = captureTotpSecretFromBody();
+        submitTotpSetupCode(TotpGenerator.currentCode(secret));
+        WaitUtils.waitForCondition(
+                "profile TOTP success message",
+                () -> com.endava.ai.ui.core.DriverManager.getEngine().getText("body")
+                        .contains("TOTP verified and enabled successfully."),
+                "Expected TOTP setup success message."
+        );
+        return secret;
+    }
+
+    private String captureTotpSecretFromBody() {
+        String secret = WaitUtils.waitUntil(
+                this::findTotpSecretCandidate,
+                value -> value != null && !value.isBlank(),
+                Duration.ofSeconds(10),
+                Duration.ofMillis(250)
+        );
+        if (secret == null || secret.isBlank()) {
+            throw new IllegalStateException("Could not extract a Base32 TOTP secret from the profile page.");
+        }
+        return secret;
+    }
+
+    private String findTotpSecretCandidate() {
+        List<String> strongCandidates = DriverManager.getEngine().getTexts(ProfilePage.TOTP_SECRET);
+        for (String candidate : strongCandidates) {
+            String extracted = extractBase32(candidate);
+            if (extracted != null) {
+                return extracted;
+            }
+        }
+
+        return extractBase32(DriverManager.getEngine().getText("body"));
+    }
+
+    private String extractBase32(String source) {
+        if (source == null || source.isBlank()) {
+            return null;
+        }
+        Matcher matcher = TOTP_SECRET_PATTERN.matcher(source);
+        return matcher.find() ? matcher.group() : null;
+    }
+}
