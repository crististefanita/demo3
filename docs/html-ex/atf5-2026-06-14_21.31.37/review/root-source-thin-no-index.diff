index 0000000..6a06053
--- /dev/null
+++ b/src/test/java/com/endava/ai/atf/ui/AuthenticatedProfileLocationMutationTests.java
@@ -0,0 +1,184 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.pages.ProfilePage;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.Assert;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+import java.time.Duration;
+
+public class AuthenticatedProfileLocationMutationTests extends BaseTestUI {
+
+    private static final String COUNTRY = "input[data-test='country']";
+    private static final String UPDATE_PROFILE_BUTTON = "button[data-test='update-profile-submit']";
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated profile location mutation preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Positive: profile postal-only update persists on submit")
+    public void positive_profile_postal_only_update_persists_on_submit() {
+        RegistrationData registered = registerAndLoginForProfileEditing();
+        RegistrationData updated = newPostalCountryVariant(registered, "postal-only", true, false);
+
+        updateProfileLocation(updated);
+
+        assertPostalAndCountry(updated);
+        assertStreetCityState(registered);
+    }
+
+    @Test(description = "Positive: profile country-only update persists on submit")
+    public void positive_profile_country_only_update_persists_on_submit() {
+        RegistrationData registered = registerAndLoginForProfileEditing();
+        RegistrationData updated = newPostalCountryVariant(registered, "country-only", false, true);
+
+        updateProfileLocation(updated);
+
+        assertPostalAndCountry(updated);
+        assertStreetCityState(registered);
+    }
+
+    @Test(description = "Positive: profile postal and country update survives same-session route replay")
+    public void positive_profile_postal_and_country_update_survives_same_session_route_replay() {
+        RegistrationData registered = registerAndLoginForProfileEditing();
+        RegistrationData updated = newPostalCountryVariant(registered, "route-replay", true, true);
+
+        updateProfileLocation(updated);
+        UIActions.navigateToRelative("/account");
+        profileService.openProfile();
+
+        assertPostalAndCountry(updated);
+        assertStreetCityState(registered);
+    }
+
+    @Test(description = "Positive: profile postal and country update survives a fresh relogin")
+    public void positive_profile_postal_and_country_update_survives_fresh_relogin() {
+        RegistrationData registered = registerAndLoginForProfileEditing();
+        RegistrationData updated = newPostalCountryVariant(registered, "fresh-relogin", true, true);
+
+        updateProfileLocation(updated);
+        UIActions.clearSession();
+        loginService.login(registered.email(), registered.password());
+        profileService.openProfile();
+
+        assertPostalAndCountry(updated);
+        assertStreetCityState(registered);
+    }
+
+    @Test(description = "Positive: profile postal and country update preserves existing street city and state")
+    public void positive_profile_postal_and_country_update_preserves_existing_street_city_and_state() {
+        RegistrationData registered = registerAndLoginForProfileEditing();
+        RegistrationData updated = newPostalCountryVariant(registered, "preserve-address", true, true);
+
+        updateProfileLocation(updated);
+
+        assertStreetCityState(registered);
+        assertPostalAndCountry(updated);
+    }
+
+    private RegistrationData registerAndLoginForProfileEditing() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+        profileValidation.assertProfileAddressPrefilled(data);
+        return data;
+    }
+
+    private RegistrationData newPostalCountryVariant(RegistrationData baseline,
+                                                     String label,
+                                                     boolean mutatePostal,
+                                                     boolean mutateCountry) {
+        String token = Long.toUnsignedString(System.nanoTime());
+        String suffix = token.substring(Math.max(0, token.length() - 4));
+
+        return baseline.toBuilder()
+                .postal(mutatePostal ? "88" + suffix : baseline.postal())
+                .country(mutateCountry ? ("ZZ-" + label + "-" + suffix) : baseline.country())
+                .build();
+    }
+
+    private void updateProfileLocation(RegistrationData updated) {
+        WaitUtils.waitForInputValue(ProfilePage.STREET, "Profile street hydration", value -> value != null && !value.isBlank());
+        WaitUtils.waitForInputValue(ProfilePage.POSTAL, "Profile postal hydration", value -> value != null && !value.isBlank());
+
+        UIActions.type(ProfilePage.POSTAL, "Profile postal", updated.postal());
+        UIActions.type(COUNTRY, "Profile country", updated.country());
+        UIActions.click(UPDATE_PROFILE_BUTTON, "Update Profile");
+
+        WaitUtils.waitForCondition(
+                "profile location update confirmation or persisted field state",
+                () -> {
+                    String body = DriverManager.getEngine().getText("body");
+                    String postal = DriverManager.getEngine().getValue(ProfilePage.POSTAL);
+                    String country = DriverManager.getEngine().getValue(COUNTRY);
+                    return body.contains("Your profile is successfully updated")
+                            || (updated.postal().equals(postal) && updated.country().equals(country));
+                },
+                "Expected profile location update success banner or persisted field state."
+        );
+        WaitUtils.pause(Duration.ofSeconds(1));
+    }
+
+    private void assertPostalAndCountry(RegistrationData expected) {
+        WaitUtils.waitForInputValue(
+                ProfilePage.POSTAL,
+                "Profile postal value",
+                value -> expected.postal().equals(value)
+        );
+        WaitUtils.waitForInputValue(
+                COUNTRY,
+                "Profile country value",
+                value -> expected.country().equals(value)
+        );
+
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.POSTAL, "Profile postal"),
+                expected.postal(),
+                "Profile postal should match the updated value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(COUNTRY, "Profile country"),
+                expected.country(),
+                "Profile country should match the updated value."
+        );
+    }
+
+    private void assertStreetCityState(RegistrationData expected) {
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.STREET, "Profile street"),
+                expected.street(),
+                "Profile street should stay unchanged."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.CITY, "Profile city"),
+                expected.city(),
+                "Profile city should stay unchanged."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.STATE, "Profile state"),
+                expected.state(),
+                "Profile state should stay unchanged."
+        );
+    }
+}
