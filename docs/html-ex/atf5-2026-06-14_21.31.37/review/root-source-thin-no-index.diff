+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.validation.LoginValidation;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.DataGenerator;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedProfileTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final LoginValidation loginValidation = new LoginValidation();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated profile preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Positive: registered user profile is prefilled with account data")
+    public void positive_registered_user_profile_is_prefilled() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+
+        profileValidation.assertProfilePrefilled(data);
+    }
+
+    @Test(description = "Positive: registered user profile keeps address fields prefilled")
+    public void positive_registered_user_profile_address_is_prefilled() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+
+        profileValidation.assertProfileAddressPrefilled(data);
+    }
+
+    @Test(description = "Positive: registered user profile keeps lookup-resolved address fields")
+    public void positive_registered_user_profile_keeps_lookup_resolved_address() {
+        registrationService.openRegister();
+        RegistrationData data = com.endava.ai.ui.factory.UserDataFactory.validRegistrationData();
+        registrationService.fillIdentityFields(data);
+        registrationService.fillAddressLookup(data.country(), data.postal(), data.houseNumber());
+        RegistrationData resolved = registrationService.waitForAutofilledAddress(data);
+        registrationService.submitRegistration();
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.loginWithoutOpen(resolved.email(), resolved.password());
+        profileService.openProfile();
+
+        profileValidation.assertProfileAddressPrefilled(resolved);
+    }
+
+    @Test(description = "Negative: even a valid password change attempt does not allow a fresh login with the proposed new password")
+    public void negative_valid_password_change_attempt_does_not_allow_relogin_with_the_new_password() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+
+        String newPassword = DataGenerator.strongPassword();
+        profileService.changePassword(data.password(), newPassword);
+
+        UIActions.clearSession();
+        loginService.attemptPrimaryCredentialLogin(data.email(), newPassword);
+
+        loginValidation.assertCurrentUrlContainsLogin();
+        loginValidation.assertPrimaryCredentialFormVisible();
+        loginValidation.assertCredentialLoginErrorContains("Invalid email or password");
+    }
+}
diff --git a/src/test/java/com/endava/ai/atf/ui/AuthenticatedPasswordChangeBoundaryTests.java b/src/test/java/com/endava/ai/atf/ui/AuthenticatedPasswordChangeBoundaryTests.java
new file mode 100644
index 0000000..6d1c8fb
--- /dev/null
+++ b/src/test/java/com/endava/ai/atf/ui/AuthenticatedPasswordChangeBoundaryTests.java
@@ -0,0 +1,93 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.LoginValidation;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedPasswordChangeBoundaryTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final LoginValidation loginValidation = new LoginValidation();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated password change boundary preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Negative: a valid password change attempt also rejects a fresh login with the old password")
+    public void negative_valid_password_change_attempt_also_rejects_a_fresh_login_with_the_old_password() {
+        RegistrationData data = registerAndLoginForPasswordChange();
+        String proposedPassword = strongCandidate("valid-old-still-works");
+
+        profileService.changePassword(data.password(), proposedPassword);
+
+        assertRejectedFreshLogin(data.email(), data.password());
+    }
+
+    @Test(description = "Negative: a wrong current password attempt does not allow a fresh login with the proposed new password")
+    public void negative_wrong_current_password_attempt_does_not_allow_login_with_the_proposed_new_password() {
+        RegistrationData data = registerAndLoginForPasswordChange();
+        String proposedPassword = strongCandidate("wrong-current");
+
+        profileService.changePassword("WrongPass1!", proposedPassword);
+
+        assertRejectedFreshLogin(data.email(), proposedPassword);
+    }
+
+    @Test(description = "Negative: a mismatched password confirmation does not allow a fresh login with the proposed new password")
+    public void negative_mismatched_password_confirmation_does_not_allow_login_with_the_proposed_new_password() {
+        RegistrationData data = registerAndLoginForPasswordChange();
+        String proposedPassword = strongCandidate("mismatch");
+
+        profileService.changePassword(data.password(), proposedPassword, proposedPassword + "Mismatch");
+
+        assertRejectedFreshLogin(data.email(), proposedPassword);
+    }
+
+    @Test(description = "Negative: a weak new password does not allow a fresh login with the proposed replacement")
+    public void negative_weak_new_password_does_not_allow_login_with_the_proposed_replacement() {
+        RegistrationData data = registerAndLoginForPasswordChange();
+
+        profileService.changePassword(data.password(), "weak");
+
+        assertRejectedFreshLogin(data.email(), "weak");
+    }
+
+    private RegistrationData registerAndLoginForPasswordChange() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+        profileValidation.assertProfilePrefilled(data);
+        return data;
+    }
+
+    private void assertRejectedFreshLogin(String email, String password) {
+        UIActions.clearSession();
+        loginService.attemptPrimaryCredentialLogin(email, password);
+        loginValidation.assertCurrentUrlContainsLogin();
+        loginValidation.assertPrimaryCredentialFormVisible();
+        loginValidation.assertCredentialLoginErrorContains("Invalid email or password");
+    }
+
+    private String strongCandidate(String label) {
+        String suffix = Long.toUnsignedString(System.nanoTime());
+        String tail = suffix.substring(Math.max(0, suffix.length() - 4));
+        return "Bb2@" + label.substring(0, Math.min(label.length(), 6)) + tail + "Z";
+    }
+}
