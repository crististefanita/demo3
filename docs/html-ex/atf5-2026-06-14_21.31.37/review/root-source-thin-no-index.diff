@@ -0,0 +1,124 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.Assert;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedTotpTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated TOTP preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Negative: empty TOTP setup code is rejected from the authenticated profile")
+    public void negative_empty_totp_setup_code_is_rejected_from_authenticated_profile() {
+        registerAndLoginForTotp();
+
+        profileService.submitEmptyTotpSetupCode();
+
+        profileValidation.assertTotpErrorContains("Invalid TOTP code. Please try again.");
+    }
+
+    @Test(description = "Negative: invalid TOTP setup code is rejected from the authenticated profile")
+    public void negative_invalid_totp_setup_code_is_rejected_from_authenticated_profile() {
+        registerAndLoginForTotp();
+
+        profileService.submitTotpSetupCode("000000");
+
+        profileValidation.assertTotpErrorContains("Invalid TOTP code. Please try again.");
+    }
+
+    @Test(description = "Positive: valid TOTP setup code enables two-factor authentication from the profile")
+    public void positive_valid_totp_setup_code_enables_two_factor_authentication_from_profile() {
+        registerAndLoginForTotp();
+
+        profileService.enableTotp();
+
+        profileValidation.assertTotpEnabledSuccess();
+    }
+
+    @Test(description = "Positive: enabled TOTP survives same-session profile replay")
+    public void positive_enabled_totp_survives_same_session_profile_replay() {
+        registerAndLoginForTotp();
+
+        profileService.enableTotp();
+        UIActions.navigateToRelative("/account");
+        profileService.openProfile();
+
+        profileValidation.assertTotpAlreadyEnabled();
+    }
+
+    @Test(description = "Negative: profile replay after enabling TOTP shows that setup details can no longer be loaded")
+    public void negative_profile_replay_after_enabling_totp_shows_setup_details_load_error() {
+        registerAndLoginForTotp();
+
+        profileService.enableTotp();
+        profileService.openProfile();
+
+        profileValidation.assertTotpAlreadyEnabled();
+        profileValidation.assertTotpSetupDetailsLoadError();
+    }
+
+    @Test(description = "Positive: enabled TOTP blocks password-only relogin until a valid code is provided")
+    public void positive_enabled_totp_blocks_password_only_relogin_until_a_valid_code_is_provided() {
+        RegistrationData data = registerAndLoginForTotp();
+
+        String secret = profileService.enableTotp();
+        UIActions.clearSession();
+        loginService.login(data.email(), data.password());
+
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        Assert.assertTrue(
+                DriverManager.getEngine().getCurrentUrl().contains("/auth/login"),
+                "Expected fresh relogin to stop on the login TOTP challenge."
+        );
+
+        loginService.completeTotpLogin(secret);
+        profileService.openProfile();
+        profileValidation.assertTotpAlreadyEnabled();
+    }
+
+    @Test(description = "Negative: after a valid TOTP relogin, the profile still cannot reload the original setup details")
+    public void negative_profile_after_valid_totp_relogin_still_shows_setup_details_load_error() {
+        RegistrationData data = registerAndLoginForTotp();
+
+        String secret = profileService.enableTotp();
+        UIActions.clearSession();
+        loginService.login(data.email(), data.password());
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        loginService.completeTotpLogin(secret);
+
+        profileService.openProfile();
+        profileValidation.assertTotpAlreadyEnabled();
+        profileValidation.assertTotpSetupDetailsLoadError();
+    }
+
+    private RegistrationData registerAndLoginForTotp() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+        return data;
+    }
+}
