@@ -0,0 +1,61 @@
+package com.endava.ai.ui.utils;
+
+import javax.crypto.Mac;
+import javax.crypto.spec.SecretKeySpec;
+import java.nio.ByteBuffer;
+
+public final class TotpGenerator {
+
+    private static final String BASE32_ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567";
+    private static final int TIME_STEP_SECONDS = 30;
+    private static final int CODE_DIGITS = 6;
+
+    private TotpGenerator() {
+    }
+
+    public static String currentCode(String secret) {
+        long counter = System.currentTimeMillis() / 1000L / TIME_STEP_SECONDS;
+        byte[] counterBytes = ByteBuffer.allocate(8).putLong(counter).array();
+        byte[] secretBytes = decodeBase32(secret);
+
+        try {
+            Mac mac = Mac.getInstance("HmacSHA1");
+            mac.init(new SecretKeySpec(secretBytes, "HmacSHA1"));
+            byte[] hash = mac.doFinal(counterBytes);
+
+            int offset = hash[hash.length - 1] & 0x0F;
+            int binary = ((hash[offset] & 0x7F) << 24)
+                    | ((hash[offset + 1] & 0xFF) << 16)
+                    | ((hash[offset + 2] & 0xFF) << 8)
+                    | (hash[offset + 3] & 0xFF);
+
+            int code = binary % (int) Math.pow(10, CODE_DIGITS);
+            return String.format("%0" + CODE_DIGITS + "d", code);
+        } catch (Exception e) {
+            throw new IllegalStateException("Failed generating TOTP code.", e);
+        }
+    }
+
+    private static byte[] decodeBase32(String value) {
+        String normalized = value == null ? "" : value.replace("=", "").replaceAll("\\s+", "").toUpperCase();
+        if (normalized.isBlank()) {
+            throw new IllegalArgumentException("TOTP secret must not be blank.");
+        }
+
+        StringBuilder bits = new StringBuilder(normalized.length() * 5);
+        for (char ch : normalized.toCharArray()) {
+            int index = BASE32_ALPHABET.indexOf(ch);
+            if (index < 0) {
+                throw new IllegalArgumentException("Unsupported Base32 character in TOTP secret: " + ch);
+            }
+            bits.append(String.format("%5s", Integer.toBinaryString(index)).replace(' ', '0'));
+        }
+
+        byte[] bytes = new byte[bits.length() / 8];
+        for (int i = 0; i < bytes.length; i++) {
+            int start = i * 8;
+            bytes[i] = (byte) Integer.parseInt(bits.substring(start, start + 8), 2);
+        }
+        return bytes;
+    }
+}
