+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.service.FavoritesService;
+import com.endava.ai.ui.service.InvoicesService;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.FavoritesValidation;
+import com.endava.ai.ui.validation.InvoicesValidation;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedAccountSurfaceOwnershipTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final FavoritesService favoritesService = new FavoritesService();
+    private final FavoritesValidation favoritesValidation = new FavoritesValidation();
+    private final InvoicesService invoicesService = new InvoicesService();
+    private final InvoicesValidation invoicesValidation = new InvoicesValidation();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated account surface ownership preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Positive: registered user can reach the authenticated favorites route")
+    public void positive_registered_user_can_reach_the_authenticated_favorites_route() {
+        registerAndLoginFreshCustomer();
+
+        favoritesService.openFavorites();
+
+        favoritesValidation.assertFavoritesRouteLoaded();
+    }
+
+    @Test(description = "Positive: authenticated favorites route survives same-session account replay")
+    public void positive_authenticated_favorites_route_survives_same_session_account_replay() {
+        registerAndLoginFreshCustomer();
+
+        favoritesService.openFavorites();
+        favoritesValidation.assertFavoritesRouteLoaded();
+
+        UIActions.navigateToRelative("/account");
+        favoritesService.openFavorites();
+        favoritesValidation.assertFavoritesRouteLoaded();
+    }
+
+    @Test(description = "Positive: authenticated favorites route survives a fresh relogin for the same customer")
+    public void positive_authenticated_favorites_route_survives_a_fresh_relogin_for_the_same_customer() {
+        RegistrationData data = registerAndLoginFreshCustomer();
+
+        favoritesService.openFavorites();
+        favoritesValidation.assertFavoritesRouteLoaded();
+
+        UIActions.clearSession();
+        loginService.login(data.email(), data.password());
+        favoritesService.openFavorites();
+
+        favoritesValidation.assertFavoritesRouteLoaded();
+    }
+
+    @Test(description = "Positive: fresh authenticated customer starts with an owned empty invoices surface")
+    public void positive_fresh_authenticated_customer_starts_with_an_owned_empty_invoices_surface() {
+        registerAndLoginFreshCustomer();
+
+        invoicesService.openInvoices();
+
+        invoicesValidation.assertInvoicesRouteLoaded();
+        invoicesValidation.assertNoInvoiceRowsPresent();
+    }
+
+    @Test(description = "Positive: profile identity and empty invoices surface survive a fresh relogin for the same customer")
+    public void positive_profile_identity_and_empty_invoices_surface_survive_a_fresh_relogin_for_the_same_customer() {
+        RegistrationData data = registerAndLoginFreshCustomer();
+
+        profileService.openProfile();
+        profileValidation.assertProfilePrefilled(data);
+
+        UIActions.clearSession();
+        loginService.login(data.email(), data.password());
+        profileService.openProfile();
+        profileValidation.assertProfilePrefilled(data);
+        invoicesService.openInvoices();
+
+        invoicesValidation.assertNoInvoiceRowsPresent();
+    }
+
+    private RegistrationData registerAndLoginFreshCustomer() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginService.loginWithoutOpen(data.email(), data.password());
+        return data;
+    }
+}
