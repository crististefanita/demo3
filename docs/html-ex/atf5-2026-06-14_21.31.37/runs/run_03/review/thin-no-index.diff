+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.InvoicesPage;
+import com.endava.ai.ui.pages.ProfilePage;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class InvoicesValidation {
+
+    public void assertInvoicesRouteLoaded() {
+        String currentUrl = DriverManager.getEngine().getCurrentUrl();
+        Assert.assertTrue(
+                currentUrl.contains(InvoicesPage.PAGE_URL_FRAGMENT),
+                "Expected authenticated invoices route, but was: " + currentUrl
+        );
+        Assert.assertTrue(
+                DriverManager.getEngine().isVisible(ProfilePage.ACCOUNT_MENU),
+                "Expected authenticated account menu to remain visible on invoices route."
+        );
+    }
+
+    public void assertNoInvoiceRowsPresent() {
+        WaitUtils.waitForVisible(InvoicesPage.PAGE_TITLE);
+
+        Assert.assertTrue(
+                DriverManager.getEngine().getCurrentUrl().contains(InvoicesPage.PAGE_URL_FRAGMENT),
+                "Expected invoices route before asserting the invoice table state."
+        );
+        Assert.assertTrue(
+                DriverManager.getEngine().getVisibleTexts(InvoicesPage.INVOICE_ROWS).isEmpty(),
+                "Expected no invoice rows for the current customer."
+        );
+    }
+}
