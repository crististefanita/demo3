+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.pages.ProfilePage;
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.utils.TotpGenerator;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class LoginService {
+
+    public void openLogin() {
+        UIActions.navigateToRelative("/auth/login");
+        WaitUtils.waitForVisible(LoginPage.EMAIL);
+    }
+
+    public void login(String email, String password) {
+        openLogin();
+        loginWithoutOpen(email, password);
+    }
+
+    public void loginWithoutOpen(String email, String password) {
+        submitPrimaryCredentialsWithoutWait(email, password);
+        WaitUtils.waitForCondition(
+                "login leaves the login surface, exposes the account menu or reaches TOTP verification",
+                () -> isAccountMenuVisible() || leftLoginSurface() || isTotpChallengeVisible(),
+                "Expected login to leave the login surface, expose the account menu or reach the TOTP challenge."
+        );
+    }
+
+    public void attemptPrimaryCredentialLogin(String email, String password) {
+        openLogin();
+        submitPrimaryCredentialsWithoutWait(email, password);
+    }
+
+    public void completeTotpLogin(String secret) {
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        UIActions.type(LoginPage.TOTP_CODE, "Login TOTP code", TotpGenerator.currentCode(secret));
+        UIActions.click(LoginPage.VERIFY_TOTP_BUTTON, "Verify TOTP");
+        WaitUtils.waitForCondition(
+                "login leaves TOTP challenge",
+                () -> isAccountMenuVisible() || leftLoginSurface(),
+                "Expected TOTP verification to finish the login."
+        );
+    }
+
+    public void submitEmptyTotpChallenge() {
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        UIActions.click(LoginPage.VERIFY_TOTP_BUTTON, "Verify TOTP");
+    }
+
+    public void submitTotpChallengeCode(String code) {
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        UIActions.type(LoginPage.TOTP_CODE, "Login TOTP code", code);
+        UIActions.click(LoginPage.VERIFY_TOTP_BUTTON, "Verify TOTP");
+    }
+
+    public void reopenLoginSurfaceFromTotpChallenge() {
+        WaitUtils.waitForVisible(LoginPage.TOTP_CODE);
+        UIActions.openRelativeWithoutUrlWait("/auth/login");
+        WaitUtils.waitForCondition(
+                "credential login surface is restored",
+                this::isPrimaryCredentialFormVisible,
+                "Expected reopening the login surface to restore the primary credential form."
+        );
+    }
+
+    public boolean isPrimaryCredentialFormVisible() {
+        try {
+            return DriverManager.getEngine().isVisible(LoginPage.EMAIL)
+                    && DriverManager.getEngine().isVisible(LoginPage.PASSWORD)
+                    && DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON)
+                    && !isTotpChallengeVisible();
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+
+    private boolean isTotpChallengeVisible() {
+        try {
+            return DriverManager.getEngine().isVisible(LoginPage.TOTP_CODE);
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+
+    private boolean isAccountMenuVisible() {
+        try {
+            return DriverManager.getEngine().isVisible(ProfilePage.ACCOUNT_MENU);
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+
+    private void submitPrimaryCredentialsWithoutWait(String email, String password) {
+        UIActions.type(LoginPage.EMAIL, "Email", email);
+        UIActions.type(LoginPage.PASSWORD, "Password", password);
+        UIActions.click(LoginPage.LOGIN_BUTTON, "Login");
+    }
+
+    private boolean leftLoginSurface() {
+        try {
+            String currentUrl = DriverManager.getEngine().getCurrentUrl();
+            boolean loginButtonVisible = DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON);
+            return !currentUrl.contains("/auth/login") && !loginButtonVisible;
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+}
