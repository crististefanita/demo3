@@ -0,0 +1,157 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.ProfileService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.LoginValidation;
+import com.endava.ai.ui.validation.ProfileValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class LoginTotpChallengeTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final LoginValidation loginValidation = new LoginValidation();
+    private final ProfileService profileService = new ProfileService();
+    private final ProfileValidation profileValidation = new ProfileValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Login TOTP challenge preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Negative: empty login TOTP code is rejected from the relogin challenge")
+    public void negative_empty_login_totp_code_is_rejected_from_the_relogin_challenge() {
+        reachEnabledTotpLoginChallenge();
+
+        loginService.submitEmptyTotpChallenge();
+
+        loginValidation.assertTotpChallengeErrorContains("TOTP code is required");
+        loginValidation.assertTotpChallengeVisible();
+        loginValidation.assertCurrentUrlContainsLogin();
+    }
+
+    @Test(description = "Negative: invalid login TOTP code is rejected from the relogin challenge")
+    public void negative_invalid_login_totp_code_is_rejected_from_the_relogin_challenge() {
+        reachEnabledTotpLoginChallenge();
+
+        loginService.submitTotpChallengeCode("000000");
+
+        loginValidation.assertTotpChallengeErrorContains("Invalid TOTP");
+        loginValidation.assertTotpChallengeVisible();
+        loginValidation.assertCurrentUrlContainsLogin();
+    }
+
+    @Test(description = "Negative: invalid login TOTP code keeps the relogin challenge open")
+    public void negative_invalid_login_totp_code_keeps_the_relogin_challenge_open() {
+        reachEnabledTotpLoginChallenge();
+
+        loginService.submitTotpChallengeCode("000000");
+
+        loginValidation.assertTotpChallengeVisible();
+        loginValidation.assertCurrentUrlContainsLogin();
+    }
+
+    @Test(description = "Negative: reopening the login surface during the TOTP challenge resets to the primary credential form")
+    public void negative_reopening_the_login_surface_during_the_totp_challenge_resets_to_primary_credentials() {
+        reachEnabledTotpLoginChallenge();
+
+        loginService.reopenLoginSurfaceFromTotpChallenge();
+
+        loginValidation.assertPrimaryCredentialFormVisible();
+        loginValidation.assertCurrentUrlContainsLogin();
+    }
+
+    @Test(description = "Positive: credential replay after a challenge reset reopens the login TOTP challenge")
+    public void positive_credential_replay_after_a_challenge_reset_reopens_the_login_totp_challenge() {
+        TotpChallengeContext context = reachEnabledTotpLoginChallenge();
+
+        loginService.reopenLoginSurfaceFromTotpChallenge();
+        loginValidation.assertPrimaryCredentialFormVisible();
+
+        loginService.loginWithoutOpen(context.data().email(), context.data().password());
+
+        loginValidation.assertTotpChallengeVisible();
+        loginValidation.assertCurrentUrlContainsLogin();
+    }
+
+    @Test(description = "Positive: a fresh valid TOTP code completes login after an invalid challenge attempt")
+    public void positive_valid_login_totp_code_completes_login_after_an_invalid_challenge_attempt() {
+        TotpChallengeContext context = reachEnabledTotpLoginChallenge();
+
+        loginService.submitTotpChallengeCode("000000");
+        loginValidation.assertTotpChallengeErrorContains("Invalid TOTP");
+        loginValidation.assertTotpChallengeVisible();
+
+        loginService.completeTotpLogin(context.secret());
+        profileService.openProfile();
+        profileValidation.assertTotpAlreadyEnabled();
+    }
+
+    @Test(description = "Positive: a fresh valid TOTP code completes login after an empty challenge submit")
+    public void positive_valid_login_totp_code_completes_login_after_an_empty_challenge_submit() {
+        TotpChallengeContext context = reachEnabledTotpLoginChallenge();
+
+        loginService.submitEmptyTotpChallenge();
+        loginValidation.assertTotpChallengeErrorContains("TOTP code is required");
+        loginValidation.assertTotpChallengeVisible();
+
+        loginService.completeTotpLogin(context.secret());
+        profileService.openProfile();
+        profileValidation.assertTotpAlreadyEnabled();
+    }
+
+    @Test(description = "Positive: a fresh valid TOTP code completes login after a challenge reset and credential replay")
+    public void positive_valid_login_totp_code_completes_login_after_a_challenge_reset_and_credential_replay() {
+        TotpChallengeContext context = reachEnabledTotpLoginChallenge();
+
+        loginService.reopenLoginSurfaceFromTotpChallenge();
+        loginValidation.assertPrimaryCredentialFormVisible();
+        loginService.loginWithoutOpen(context.data().email(), context.data().password());
+        loginValidation.assertTotpChallengeVisible();
+
+        loginService.completeTotpLogin(context.secret());
+        profileService.openProfile();
+        profileValidation.assertTotpAlreadyEnabled();
+    }
+
+    private TotpChallengeContext reachEnabledTotpLoginChallenge() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginService.loginWithoutOpen(data.email(), data.password());
+        profileService.openProfile();
+        String secret = profileService.enableTotp();
+        profileValidation.assertTotpEnabledSuccess();
+        UIActions.clearSession();
+        loginService.login(data.email(), data.password());
+        loginValidation.assertTotpChallengeVisible();
+        return new TotpChallengeContext(data, secret);
+    }
+
+    private static final class TotpChallengeContext {
+        private final RegistrationData data;
+        private final String secret;
+
+        private TotpChallengeContext(RegistrationData data, String secret) {
+            this.data = data;
+            this.secret = secret;
+        }
+
+        private RegistrationData data() {
+            return data;
+        }
+
+        private String secret() {
+            return secret;
+        }
+    }
+}
