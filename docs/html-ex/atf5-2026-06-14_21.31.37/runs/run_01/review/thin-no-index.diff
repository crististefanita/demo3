+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class LoginValidation {
+
+    public void assertTotpChallengeVisible() {
+        WaitUtils.waitForCondition(
+                "login TOTP challenge is visible",
+                () -> safeVisible(LoginPage.TOTP_CODE) && safeVisible(LoginPage.VERIFY_TOTP_BUTTON),
+                "Expected the login TOTP challenge to be visible."
+        );
+    }
+
+    public void assertTotpChallengeErrorContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "login body contains TOTP challenge error",
+                () -> DriverManager.getEngine().getText("body").contains(expectedText),
+                "Expected login surface to contain '" + expectedText + "'."
+        );
+
+        String bodyText = DriverManager.getEngine().getText("body");
+        Assert.assertTrue(
+                bodyText.contains(expectedText),
+                "Expected login body to contain '" + expectedText + "', but was: " + bodyText
+        );
+    }
+
+    public void assertCurrentUrlContainsLogin() {
+        WaitUtils.waitForCondition(
+                "current URL remains on login",
+                () -> DriverManager.getEngine().getCurrentUrl().contains("/auth/login"),
+                "Expected current URL to remain on /auth/login."
+        );
+    }
+
+    public void assertPrimaryCredentialFormVisible() {
+        WaitUtils.waitForCondition(
+                "primary login credentials are visible",
+                () -> safeVisible(LoginPage.EMAIL)
+                        && safeVisible(LoginPage.PASSWORD)
+                        && safeVisible(LoginPage.LOGIN_BUTTON)
+                        && !safeVisible(LoginPage.TOTP_CODE),
+                "Expected the primary email/password login form to be visible."
+        );
+    }
+
+    public void assertCredentialLoginErrorContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "primary login error contains expected text",
+                () -> safeVisible(LoginPage.LOGIN_ERROR)
+                        && DriverManager.getEngine().getText(LoginPage.LOGIN_ERROR).contains(expectedText),
+                "Expected login error to contain '" + expectedText + "'."
+        );
+
+        String errorText = DriverManager.getEngine().getText(LoginPage.LOGIN_ERROR);
+        Assert.assertTrue(
+                errorText.contains(expectedText),
+                "Expected login error to contain '" + expectedText + "', but was: " + errorText
+        );
+    }
+
+    private boolean safeVisible(String locator) {
+        try {
+            return DriverManager.getEngine().isVisible(locator);
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+}
