+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.pages.ProfilePage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class ProfileValidation {
+
+    public void assertProfilePrefilled(RegistrationData data) {
+        WaitUtils.waitForInputValue(
+                ProfilePage.EMAIL,
+                "Profile email value",
+                value -> data.email().equals(value)
+        );
+
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.FIRST_NAME, "Profile first name"),
+                data.firstName(),
+                "Profile first name should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.LAST_NAME, "Profile last name"),
+                data.lastName(),
+                "Profile last name should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.EMAIL, "Profile email"),
+                data.email(),
+                "Profile email should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.PHONE, "Profile phone"),
+                data.phone(),
+                "Profile phone should match registered value."
+        );
+    }
+
+    public void assertProfileAddressPrefilled(RegistrationData data) {
+        WaitUtils.waitForInputValue(
+                ProfilePage.STREET,
+                "Profile street value",
+                value -> data.street().equals(value)
+        );
+        WaitUtils.waitForInputValue(
+                ProfilePage.CITY,
+                "Profile city value",
+                value -> data.city().equals(value)
+        );
+        WaitUtils.waitForInputValue(
+                ProfilePage.STATE,
+                "Profile state value",
+                value -> data.state().equals(value)
+        );
+        WaitUtils.waitForInputValue(
+                ProfilePage.POSTAL,
+                "Profile postal value",
+                value -> data.postal().equals(value)
+        );
+
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.STREET, "Profile street"),
+                data.street(),
+                "Profile street should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.CITY, "Profile city"),
+                data.city(),
+                "Profile city should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.STATE, "Profile state"),
+                data.state(),
+                "Profile state should match registered value."
+        );
+        Assert.assertEquals(
+                UIActions.getValue(ProfilePage.POSTAL, "Profile postal"),
+                data.postal(),
+                "Profile postal should match registered value."
+        );
+    }
+
+    public void assertPasswordChangeSucceeded() {
+        WaitUtils.waitForCondition(
+                "password change success banner or text",
+                () -> {
+                    String banner = UIActions.getText(ProfilePage.SUCCESS_BANNER, "Success banner");
+                    String body = DriverManager.getEngine().getText("body");
+                    return banner.contains("successfully changed")
+                            || body.contains("Your password is successfully changed");
+                },
+                "Expected password change success message."
+        );
+    }
+
+    public void assertTotpErrorContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "profile TOTP error contains expected text",
+                () -> DriverManager.getEngine().getText(ProfilePage.TOTP_ERROR).contains(expectedText),
+                "Expected profile TOTP error to contain '" + expectedText + "'."
+        );
+
+        String text = UIActions.getText(ProfilePage.TOTP_ERROR, "Profile TOTP error");
+        Assert.assertTrue(
+                text.contains(expectedText),
+                "Expected profile TOTP error to contain '" + expectedText + "', but was: " + text
+        );
+    }
+
+    public void assertTotpEnabledSuccess() {
+        WaitUtils.waitForCondition(
+                "profile TOTP success text",
+                () -> DriverManager.getEngine().getText("body").contains("TOTP verified and enabled successfully."),
+                "Expected TOTP verification success text."
+        );
+    }
+
+    public void assertTotpAlreadyEnabled() {
+        WaitUtils.waitForCondition(
+                "profile TOTP already enabled text",
+                () -> DriverManager.getEngine().getText("body").contains("Two-Factor Authentication already enabled."),
+                "Expected profile to show that TOTP is already enabled."
+        );
+    }
+
+    public void assertTotpSetupDetailsLoadError() {
+        WaitUtils.waitForCondition(
+                "profile TOTP setup details load error text",
+                () -> DriverManager.getEngine().getText("body").contains("Failed to load TOTP setup details."),
+                "Expected profile to show the post-enable TOTP setup details load error."
+        );
+    }
+}
