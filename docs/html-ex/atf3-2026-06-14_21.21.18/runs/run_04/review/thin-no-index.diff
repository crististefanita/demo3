+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.pages.StorefrontPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class CheckoutValidation {
+
+    public void assertCartHasLineItem() {
+        WaitUtils.waitForVisible(StorefrontPage.PRODUCT_TITLE);
+        String title = UIActions.getText(StorefrontPage.PRODUCT_TITLE, "Cart product title");
+        Assert.assertFalse(title.isBlank(), "Expected the cart to expose a product line item.");
+    }
+
+    public void assertGuestIdentityAccepted(CustomerData customer) {
+        WaitUtils.waitForCondition(
+                "guest identity banner contains the provided guest",
+                () -> safeText("body").contains("Continuing as guest: " + customer.getFirstName() + " " + customer.getLastName()),
+                "Expected checkout to accept the guest identity before billing."
+        );
+    }
+
+    public void assertPaymentSuccess() {
+        WaitUtils.waitForVisible(CheckoutPage.PAYMENT_SUCCESS_MESSAGE);
+        String message = UIActions.getText(CheckoutPage.PAYMENT_SUCCESS_MESSAGE, "Payment success message");
+        Assert.assertTrue(
+                message.contains("Payment was successful"),
+                "Expected checkout to confirm payment success."
+        );
+    }
+
+    public void assertBillingLookupAutofillsAddress(CustomerData customer) {
+        WaitUtils.waitForCondition(
+                "billing lookup autofills the address fields",
+                () -> customer.getStreet().equals(UIActions.getValue(CheckoutPage.STREET, "Billing street"))
+                        && customer.getCity().equals(UIActions.getValue(CheckoutPage.CITY, "Billing city"))
+                        && customer.getState().equals(UIActions.getValue(CheckoutPage.STATE, "Billing state")),
+                "Expected billing lookup to auto-populate street, city, and state from the postal lookup key."
+        );
+
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.STREET, "Billing street"), customer.getStreet(),
+                "Expected billing street to be auto-filled.");
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.CITY, "Billing city"), customer.getCity(),
+                "Expected billing city to be auto-filled.");
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.STATE, "Billing state"), customer.getState(),
+                "Expected billing state to be auto-filled.");
+    }
+
+    public void assertBillingLookupRewritesAddress(CustomerData previousCustomer, CustomerData updatedCustomer) {
+        WaitUtils.waitForCondition(
+                "billing lookup rewrites the address fields after key mutation",
+                () -> updatedCustomer.getStreet().equals(UIActions.getValue(CheckoutPage.STREET, "Billing street after lookup rewrite"))
+                        && updatedCustomer.getCity().equals(UIActions.getValue(CheckoutPage.CITY, "Billing city after lookup rewrite"))
+                        && updatedCustomer.getState().equals(UIActions.getValue(CheckoutPage.STATE, "Billing state after lookup rewrite")),
+                "Expected billing lookup to rewrite street, city, and state after changing the lookup key."
+        );
+
+        Assert.assertNotEquals(UIActions.getValue(CheckoutPage.STREET, "Billing street after lookup rewrite"), previousCustomer.getStreet(),
+                "Expected billing street to change after the lookup key changes.");
+        Assert.assertNotEquals(UIActions.getValue(CheckoutPage.CITY, "Billing city after lookup rewrite"), previousCustomer.getCity(),
+                "Expected billing city to change after the lookup key changes.");
+        Assert.assertNotEquals(UIActions.getValue(CheckoutPage.STATE, "Billing state after lookup rewrite"), previousCustomer.getState(),
+                "Expected billing state to change after the lookup key changes.");
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.STREET, "Billing street after lookup rewrite"), updatedCustomer.getStreet(),
+                "Expected rewritten billing street to match the new lookup result.");
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.CITY, "Billing city after lookup rewrite"), updatedCustomer.getCity(),
+                "Expected rewritten billing city to match the new lookup result.");
+        Assert.assertEquals(UIActions.getValue(CheckoutPage.STATE, "Billing state after lookup rewrite"), updatedCustomer.getState(),
+                "Expected rewritten billing state to match the new lookup result.");
+    }
+
+    private String safeText(String selector) {
+        try {
+            return UIActions.getText(selector, selector);
+        } catch (AssertionError ignored) {
+            return "";
+        }
+    }
+}
