@@ -0,0 +1,149 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.AuthenticatedCheckoutService;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.service.StorefrontService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.AccountValidation;
+import com.endava.ai.ui.validation.CheckoutValidation;
+import com.endava.ai.ui.validation.InvoiceValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedPostPurchaseHistoryTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final AccountValidation accountValidation = new AccountValidation();
+    private final StorefrontService storefrontService = new StorefrontService();
+    private final AuthenticatedCheckoutService authenticatedCheckoutService = new AuthenticatedCheckoutService();
+    private final CheckoutValidation checkoutValidation = new CheckoutValidation();
+    private final AccountService accountService = new AccountService();
+    private final InvoiceValidation invoiceValidation = new InvoiceValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated post-purchase history preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Run 01: authenticated BNPL purchase does not materialize invoice history after a fresh login")
+    public void run_01_bnpl_purchase_leaves_invoice_history_empty_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+        completeBnplPurchase(customer, "3 Monthly Installments");
+        assertInvoiceHistoryEmptyAfterFreshLogin(customer);
+    }
+
+    @Test(description = "Run 02: authenticated gift-card purchase does not materialize invoice history after a fresh login")
+    public void run_02_gift_card_purchase_leaves_invoice_history_empty_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+        completeGiftCardPurchase(customer, "ABCDEFGH12345678", "W9X2");
+        assertInvoiceHistoryEmptyAfterFreshLogin(customer);
+    }
+
+    @Test(description = "Run 03: authenticated bank-transfer purchase does not materialize invoice history after a fresh login")
+    public void run_03_bank_transfer_purchase_leaves_invoice_history_empty_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+        completeBankTransferPurchase(customer);
+        assertInvoiceHistoryEmptyAfterFreshLogin(customer);
+    }
+
+    @Test(description = "Run 04: authenticated COD purchase does not materialize invoice history after a fresh login")
+    public void run_04_cod_purchase_leaves_invoice_history_empty_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+        completeCashOnDeliveryPurchase(customer);
+        assertInvoiceHistoryEmptyAfterFreshLogin(customer);
+    }
+
+    @Test(description = "Run 05: authenticated COD purchase does not materialize invoice history even before relogin")
+    public void run_05_cod_purchase_leaves_invoice_history_empty_immediately_after_success() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+        completeCashOnDeliveryPurchase(customer);
+
+        accountService.openInvoicesDirect();
+        invoiceValidation.assertInvoicesPageVisible();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    private void registerAndLogin(CustomerData customer) {
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+    }
+
+    private void startPaymentStep(CustomerData customer) {
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        storefrontService.addCurrentProductToCart();
+        storefrontService.openCart();
+        checkoutValidation.assertCartHasLineItem();
+
+        authenticatedCheckoutService.proceedFromCartToBilling(customer);
+    }
+
+    private void completeBnplPurchase(CustomerData customer, String installmentPlan) {
+        startPaymentStep(customer);
+        authenticatedCheckoutService.selectPaymentMethod("Buy Now Pay Later");
+        authenticatedCheckoutService.selectMonthlyInstallments(installmentPlan);
+        authenticatedCheckoutService.confirmSelectedPayment();
+        checkoutValidation.assertPaymentSuccess();
+    }
+
+    private void completeGiftCardPurchase(CustomerData customer, String giftCardNumber, String validationCode) {
+        startPaymentStep(customer);
+        authenticatedCheckoutService.selectPaymentMethod("Gift Card");
+        authenticatedCheckoutService.fillGiftCard(giftCardNumber, validationCode);
+        authenticatedCheckoutService.confirmSelectedPayment();
+        checkoutValidation.assertPaymentSuccess();
+    }
+
+    private void completeBankTransferPurchase(CustomerData customer) {
+        startPaymentStep(customer);
+        authenticatedCheckoutService.selectPaymentMethod("Bank Transfer");
+        authenticatedCheckoutService.fillBankTransfer(
+                "Audit Bank",
+                customer.getFirstName() + " " + customer.getLastName(),
+                "12345678901234"
+        );
+        authenticatedCheckoutService.confirmSelectedPayment();
+        checkoutValidation.assertPaymentSuccess();
+    }
+
+    private void completeCashOnDeliveryPurchase(CustomerData customer) {
+        startPaymentStep(customer);
+        authenticatedCheckoutService.confirmCashOnDelivery();
+        checkoutValidation.assertPaymentSuccess();
+    }
+
+    private void assertInvoiceHistoryEmptyAfterFreshLogin(CustomerData customer) {
+        UIActions.clearSession();
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+
+        accountService.openInvoicesDirect();
+        invoiceValidation.assertInvoicesPageVisible();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+}
