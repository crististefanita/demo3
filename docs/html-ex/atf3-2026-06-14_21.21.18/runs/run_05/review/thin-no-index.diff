+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class LoginValidation {
+
+    public void assertInvalidCredentialsRejected() {
+        WaitUtils.waitForCondition(
+                "invalid login error becomes visible",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    return url.contains("/auth/login")
+                            && DriverManager.getEngine().isVisible(LoginPage.LOGIN_ERROR)
+                            && UIActions.getText(LoginPage.LOGIN_ERROR, "Login error")
+                            .contains("Invalid email or password");
+                },
+                "Expected invalid credentials to keep the visitor on login and show the rejection message."
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String error = UIActions.getText(LoginPage.LOGIN_ERROR, "Login error");
+        Assert.assertTrue(url.contains("/auth/login"), "Expected to remain on /auth/login, but was: " + url);
+        Assert.assertEquals(error, "Invalid email or password", "Expected the exact invalid-login error message.");
+    }
+
+    public void assertTotpChallengeVisible() {
+        WaitUtils.waitForCondition(
+                "login switches to the TOTP challenge",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    return url.contains("/auth/login")
+                            && DriverManager.getEngine().isVisible(LoginPage.TOTP_CODE)
+                            && DriverManager.getEngine().isEnabled(LoginPage.VERIFY_TOTP_BUTTON);
+                },
+                "Expected password login to switch to the TOTP challenge."
+        );
+    }
+}
