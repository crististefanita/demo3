+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class AccountService {
+
+    public void openProfile() {
+        UIActions.click(AccountPage.NAV_PROFILE, "Profile");
+        WaitUtils.waitForUrlContains("/account/profile");
+        WaitUtils.waitForVisible(AccountPage.FIRST_NAME);
+    }
+
+    public void openProfileDirect() {
+        UIActions.navigateToRelative("/account/profile");
+        WaitUtils.waitForUrlContains("/account/profile");
+        WaitUtils.waitForVisible(AccountPage.FIRST_NAME);
+    }
+
+    public void openAccountHub() {
+        UIActions.navigateToRelative("/account");
+        WaitUtils.waitForUrlContains("/account");
+        WaitUtils.waitForVisible(AccountPage.NAV_PROFILE);
+    }
+
+    public void openInvoicesDirect() {
+        UIActions.navigateToRelative("/account/invoices");
+        WaitUtils.waitForUrlContains("/account/invoices");
+        WaitUtils.waitForVisible(AccountPage.PAGE_TITLE);
+    }
+
+    public String readTotpSecret() {
+        WaitUtils.waitForVisible(AccountPage.TOTP_SECRET);
+        return UIActions.getText(AccountPage.TOTP_SECRET, "TOTP secret");
+    }
+
+    public void openFavoritesDirect() {
+        UIActions.navigateToRelative("/account/favorites");
+        WaitUtils.waitForUrlContains("/account/favorites");
+        WaitUtils.waitForVisible(AccountPage.PAGE_TITLE);
+    }
+
+    public void removeFirstFavorite() {
+        UIActions.click(AccountPage.FAVORITE_DELETE_BUTTON, "Delete favorite");
+        WaitUtils.pause(java.time.Duration.ofMillis(750));
+    }
+
+    public void updateProfile(String firstName,
+                              String lastName,
+                              String phone,
+                              String street,
+                              String postalCode,
+                              String city,
+                              String state,
+                              String country) {
+        UIActions.type(AccountPage.FIRST_NAME, "Profile first name", firstName);
+        UIActions.type(AccountPage.LAST_NAME, "Profile last name", lastName);
+        UIActions.type(AccountPage.PHONE, "Profile phone", phone);
+        UIActions.type(AccountPage.STREET, "Profile street", street);
+        UIActions.type(AccountPage.POSTAL_CODE, "Profile postal code", postalCode);
+        UIActions.type(AccountPage.CITY, "Profile city", city);
+        UIActions.type(AccountPage.STATE, "Profile state", state);
+        UIActions.type(AccountPage.COUNTRY, "Profile country", country);
+        UIActions.click(AccountPage.UPDATE_PROFILE_BUTTON, "Update profile");
+        WaitUtils.waitForUrlContains("/account/profile");
+        WaitUtils.waitForVisible(AccountPage.FIRST_NAME);
+        WaitUtils.pause(java.time.Duration.ofMillis(900));
+    }
+
+    public void changePassword(String currentPassword, String newPassword) {
+        UIActions.type(AccountPage.CURRENT_PASSWORD, "Current password", currentPassword);
+        UIActions.type(AccountPage.NEW_PASSWORD, "New password", newPassword);
+        UIActions.type(AccountPage.NEW_PASSWORD_CONFIRM, "Confirm new password", newPassword);
+        UIActions.click(AccountPage.CHANGE_PASSWORD_BUTTON, "Change password");
+    }
+
+    public void verifyTotp(String code) {
+        UIActions.type(AccountPage.TOTP_CODE, "Profile TOTP code", code);
+        UIActions.pressKey(AccountPage.TOTP_CODE, "Profile TOTP code", "Tab");
+        UIActions.click(AccountPage.VERIFY_TOTP_BUTTON, "Verify profile TOTP");
+        WaitUtils.pause(java.time.Duration.ofMillis(1200));
+    }
+}
