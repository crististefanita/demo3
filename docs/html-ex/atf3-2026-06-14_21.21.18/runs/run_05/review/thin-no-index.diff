+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class SecurityValidation {
+
+    public void assertProfileEmailLocked() {
+        WaitUtils.waitForVisible(AccountPage.EMAIL);
+        String readonly = UIActions.getAttribute(AccountPage.EMAIL, "Profile email readonly", "readonly");
+        String disabled = UIActions.getAttribute(AccountPage.EMAIL, "Profile email disabled", "disabled");
+
+        Assert.assertTrue(
+                readonly != null || disabled != null,
+                "Expected the profile email field to stay protected from edits."
+        );
+    }
+
+    public void assertPasswordControlsVisible() {
+        WaitUtils.waitForVisible(AccountPage.CURRENT_PASSWORD);
+        WaitUtils.waitForVisible(AccountPage.NEW_PASSWORD);
+        WaitUtils.waitForVisible(AccountPage.NEW_PASSWORD_CONFIRM);
+        WaitUtils.waitForVisible(AccountPage.CHANGE_PASSWORD_BUTTON);
+        Assert.assertTrue(
+                DriverManager.getEngine().isEnabled(AccountPage.CHANGE_PASSWORD_BUTTON),
+                "Expected the password change action to stay enabled on the profile surface."
+        );
+    }
+
+    public void assertTotpEnrollmentVisible() {
+        WaitUtils.waitForVisible(AccountPage.TOTP_SECRET);
+        WaitUtils.waitForVisible(AccountPage.TOTP_CODE);
+        WaitUtils.waitForVisible(AccountPage.VERIFY_TOTP_BUTTON);
+
+        String secret = UIActions.getText(AccountPage.TOTP_SECRET, "TOTP secret");
+        Assert.assertTrue(
+                secret != null && secret.replaceAll("\\s+", "").length() >= 16,
+                "Expected the profile surface to expose a usable TOTP secret."
+        );
+        Assert.assertTrue(
+                DriverManager.getEngine().isEnabled(AccountPage.VERIFY_TOTP_BUTTON),
+                "Expected the TOTP verification action to stay enabled on the profile surface."
+        );
+    }
+
+    public void assertTotpChallengeStillVisible() {
+        WaitUtils.waitForCondition(
+                "visitor remains on the TOTP challenge",
+                () -> DriverManager.getEngine().getCurrentUrl().contains("/auth/login")
+                        && DriverManager.getEngine().isVisible(LoginPage.TOTP_CODE)
+                        && DriverManager.getEngine().isEnabled(LoginPage.VERIFY_TOTP_BUTTON),
+                "Expected the visitor to remain on the TOTP challenge instead of reaching the account hub."
+        );
+    }
+}
