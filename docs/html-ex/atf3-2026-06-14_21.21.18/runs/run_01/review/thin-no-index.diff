@@ -0,0 +1,377 @@
+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.pages.CatalogPage;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.pages.StorefrontPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+import java.time.Duration;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Locale;
+
+public final class BusinessExpansionValidation {
+
+    public void assertComparisonDestinationFor(String productName) {
+        WaitUtils.waitForCondition(
+                "comparison page becomes visible",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Comparison page body");
+                    return url.contains("/comparison")
+                            && body.contains("Product Comparison")
+                            && body.contains(productName)
+                            && body.contains("Show differences only");
+                },
+                "Expected comparison flow to land on /comparison with the selected product visible."
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String body = UIActions.getText("body", "Comparison page body");
+        Assert.assertTrue(url.contains("/comparison"), "Expected comparison route, but was: " + url);
+        Assert.assertTrue(body.contains(productName), "Expected selected product on the comparison page.");
+        Assert.assertTrue(body.contains("Product Comparison"), "Expected comparison page title.");
+    }
+
+    public void assertSecondCatalogPageShelf() {
+        WaitUtils.waitForCondition(
+                "second catalog page shelf is visible",
+                () -> {
+                    List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Catalog page 2 product names");
+                    return names.size() == 9
+                            && names.contains("Sledgehammer")
+                            && names.contains("Claw Hammer with Fiberglass Handle")
+                            && names.contains("Court Hammer")
+                            && names.contains("Wood Saw")
+                            && names.contains("Adjustable Wrench")
+                            && names.contains("Angled Spanner")
+                            && names.contains("Open-end Spanners (Set)")
+                            && names.contains("Phillips Screwdriver")
+                            && names.contains("Mini Screwdriver");
+                },
+                "Expected pagination to move the storefront to the live second-page shelf."
+        );
+
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Catalog page 2 product names");
+        Assert.assertEquals(names.size(), 9, "Expected nine visible product cards on catalog page 2.");
+        Assert.assertFalse(names.contains("Combination Pliers"), "Expected first-page shelf product Combination Pliers to disappear after pagination.");
+    }
+
+    public void assertPowerToolsForgeFlexIntersection() {
+        WaitUtils.waitForCondition(
+                "power-tools plus ForgeFlex intersection settles",
+                () -> {
+                    List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Power tools ForgeFlex product names");
+                    return names.size() == 6
+                            && names.contains("Sheet Sander")
+                            && names.contains("Random Orbit Sander")
+                            && names.contains("Circular Saw")
+                            && names.contains("Cordless Drill 20V")
+                            && names.contains("Cordless Drill 24V");
+                },
+                "Expected power-tools plus ForgeFlex intersection to settle to the live six-item subset."
+        );
+
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Power tools ForgeFlex product names");
+        Assert.assertEquals(names.size(), 6, "Expected exactly six products in the power-tools plus ForgeFlex intersection.");
+        Assert.assertFalse(names.contains("Belt Sander"), "Expected non-ForgeFlex Belt Sander to disappear after intersection narrowing.");
+        Assert.assertFalse(names.contains("Cordless Drill 12V"), "Expected Cordless Drill 12V to stay outside the ForgeFlex intersection.");
+    }
+
+    public void assertForgotPasswordConfirmation() {
+        WaitUtils.waitForCondition(
+                "forgot-password confirmation becomes visible",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Forgot password page body");
+                    return url.contains("/auth/forgot-password")
+                            && body.contains("Forgot Password")
+                            && body.contains("page.forgot-password.confirm");
+                },
+                "Expected forgot-password flow to keep the visitor on /auth/forgot-password and expose the live confirmation key."
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String body = UIActions.getText("body", "Forgot password page body");
+        Assert.assertTrue(url.contains("/auth/forgot-password"), "Expected to remain on /auth/forgot-password, but was: " + url);
+        Assert.assertTrue(body.contains("page.forgot-password.confirm"), "Expected the live forgot-password confirmation text.");
+    }
+
+    public void assertForgotPasswordRejectsUnknownEmail() {
+        WaitUtils.waitForCondition(
+                "forgot-password rejects unknown email",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Forgot password page body");
+                    return url.contains("/auth/forgot-password")
+                            && body.contains("Forgot Password")
+                            && body.contains("The selected email is invalid.");
+                },
+                "Expected forgot-password flow to reject an unknown email with visible validation feedback."
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String body = UIActions.getText("body", "Forgot password page body");
+        Assert.assertTrue(url.contains("/auth/forgot-password"), "Expected to remain on /auth/forgot-password, but was: " + url);
+        Assert.assertTrue(body.contains("The selected email is invalid."), "Expected unknown email validation feedback.");
+    }
+
+    public void assertFavoritesPageContains(String productName) {
+        Assert.assertFalse(productName == null || productName.isBlank(), "Expected a non-empty selected product name before opening favorites.");
+
+        WaitUtils.waitForCondition(
+                "favorites page contains selected product",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Favorites page body");
+                    List<String> names = UIActions.getVisibleTexts(StorefrontPage.PRODUCT_NAME, "Favorite product names");
+                    return url.contains("/account/favorites")
+                            && body.contains("Favorites")
+                            && !body.contains("There are no favorites yet")
+                            && names.contains(productName);
+                },
+                "Expected favorites page to materialize the selected product."
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String body = UIActions.getText("body", "Favorites page body");
+        List<String> names = UIActions.getVisibleTexts(StorefrontPage.PRODUCT_NAME, "Favorite product names");
+        Assert.assertTrue(url.contains("/account/favorites"), "Expected favorites route, but was: " + url);
+        Assert.assertFalse(body.contains("There are no favorites yet"), "Expected favorites page to contain at least one materialized favorite.");
+        Assert.assertTrue(names.contains(productName), "Expected the selected product to be visible in favorites.");
+    }
+
+    public String readFirstVisibleCatalogProductName() {
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Visible catalog product names");
+        Assert.assertFalse(names.isEmpty(), "Expected at least one visible catalog product.");
