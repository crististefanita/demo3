@@ -0,0 +1,119 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.service.StorefrontService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.AccountValidation;
+import com.endava.ai.ui.validation.BusinessExpansionValidation;
+import com.endava.ai.ui.validation.InvoiceValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedAccountSurfaceBreadthTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final AccountService accountService = new AccountService();
+    private final AccountValidation accountValidation = new AccountValidation();
+    private final InvoiceValidation invoiceValidation = new InvoiceValidation();
+    private final StorefrontService storefrontService = new StorefrontService();
+    private final BusinessExpansionValidation businessExpansionValidation = new BusinessExpansionValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated account surface breadth preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Run 01: authenticated account hub exposes the registered customer identity")
+    public void run_01_authenticated_account_hub_exposes_registered_customer_identity() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+
+        accountValidation.assertAccountHubVisible();
+        accountValidation.assertAccountIdentityVisible(customer.getFirstName() + " " + customer.getLastName());
+    }
+
+    @Test(description = "Run 02: authenticated profile editor replays the persisted registration values")
+    public void run_02_authenticated_profile_editor_replays_persisted_registration_values() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+
+        accountService.openProfile();
+        accountValidation.assertProfileEditorReady();
+        accountValidation.assertProfileValues(
+                customer.getFirstName(),
+                customer.getLastName(),
+                customer.getPhone(),
+                customer.getStreet(),
+                customer.getPostalCode(),
+                customer.getCity(),
+                customer.getState(),
+                customer.getCountry()
+        );
+    }
+
+    @Test(description = "Run 03: authenticated invoices route stays empty before any purchase materializes")
+    public void run_03_authenticated_invoices_route_stays_empty_before_any_purchase() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+
+        accountService.openInvoicesDirect();
+        invoiceValidation.assertInvoicesPageVisible();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "Run 04: authenticated customer can materialize a product inside account favorites")
+    public void run_04_authenticated_customer_can_materialize_a_product_inside_account_favorites() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        String productName = businessExpansionValidation.readCurrentProductTitle();
+        storefrontService.addCurrentProductToFavorites();
+
+        accountService.openFavoritesDirect();
+        businessExpansionValidation.assertFavoritesPageContains(productName);
+    }
+
+    @Test(description = "Run 05: authenticated customer can delete the only favorite back to the empty state")
+    public void run_05_authenticated_customer_can_delete_the_only_favorite_back_to_the_empty_state() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+
+        registerAndLogin(customer);
+
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        String productName = businessExpansionValidation.readCurrentProductTitle();
+        storefrontService.addCurrentProductToFavorites();
+
+        accountService.openFavoritesDirect();
+        businessExpansionValidation.assertFavoritesPageContains(productName);
+
+        accountService.removeFirstFavorite();
+        businessExpansionValidation.assertFavoritesPageReturnsToEmptyState(productName);
+    }
+
+    private void registerAndLogin(CustomerData customer) {
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+    }
+}
