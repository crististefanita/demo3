+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.pages.StorefrontPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class StorefrontService {
+
+    public void openHome() {
+        UIActions.navigateToRelative("/");
+        WaitUtils.waitForVisible(StorefrontPage.PRODUCT_LINKS);
+    }
+
+    public void openFirstProduct() {
+        UIActions.clickVisible(StorefrontPage.PRODUCT_LINKS, "First storefront product", 1);
+        WaitUtils.waitForVisible(StorefrontPage.ADD_TO_CART_BUTTON);
+    }
+
+    public void addCurrentProductToCart() {
+        UIActions.click(StorefrontPage.ADD_TO_CART_BUTTON, "Add to cart");
+        WaitUtils.waitForCondition(
+                "product add confirmation becomes visible",
+                () -> safeText("body").contains("Product added to shopping cart."),
+                "Expected add-to-cart confirmation to appear after adding a product."
+        );
+    }
+
+    public void addCurrentProductToFavorites() {
+        UIActions.click(StorefrontPage.ADD_TO_FAVORITES_BUTTON, "Add to favourites");
+        WaitUtils.pause(java.time.Duration.ofMillis(750));
+    }
+
+    public void addCurrentProductToComparison() {
+        UIActions.click(StorefrontPage.ADD_TO_COMPARE_BUTTON, "Add to compare");
+        WaitUtils.pause(java.time.Duration.ofMillis(750));
+    }
+
+    public void increaseCurrentProductQuantityBy(int incrementCount) {
+        for (int index = 0; index < incrementCount; index++) {
+            UIActions.click(StorefrontPage.INCREASE_QUANTITY_BUTTON, "Increase product quantity");
+        }
+    }
+
+    public void openCart() {
+        UIActions.click(StorefrontPage.NAV_CART, "Cart");
+        WaitUtils.waitForVisible(StorefrontPage.PROCEED_FROM_CART);
+    }
+
+    public void changeCheckoutQuantityTo(int quantity) {
+        String quantityValue = String.valueOf(quantity);
+        UIActions.type(CheckoutPage.PRODUCT_QUANTITY, "Checkout product quantity", quantityValue);
+        UIActions.pressKey(CheckoutPage.PRODUCT_QUANTITY, "Checkout product quantity", "Tab");
+        WaitUtils.pause(java.time.Duration.ofMillis(1000));
+    }
+
+    private String safeText(String selector) {
+        try {
+            return UIActions.getText(selector, selector);
+        } catch (AssertionError ignored) {
+            return "";
+        }
+    }
+}
diff --git a/src/main/java/com/endava/ai/ui/validation/AccountValidation.java b/src/main/java/com/endava/ai/ui/validation/AccountValidation.java
