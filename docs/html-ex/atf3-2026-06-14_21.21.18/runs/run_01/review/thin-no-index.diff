+
+    public String readCurrentProductTitle() {
+        WaitUtils.waitForVisible(StorefrontPage.PRODUCT_NAME);
+        String productName = UIActions.getText(StorefrontPage.PRODUCT_NAME, "Current product name");
+        Assert.assertFalse(productName == null || productName.isBlank(), "Expected a non-empty product name on the product details page.");
+        return productName;
+    }
+
+    public List<String> readFirstTwoVisibleCatalogProductNames() {
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Visible catalog product names");
+        Assert.assertTrue(names.size() >= 2, "Expected at least two visible catalog products for multi-compare.");
+        List<String> firstTwo = new ArrayList<>();
+        firstTwo.add(names.get(0));
+        firstTwo.add(names.get(1));
+        return firstTwo;
+    }
+
+    public List<String> readVisibleCatalogProductNamesAtIndices(int firstOneBasedIndex, int secondOneBasedIndex) {
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Visible catalog product names");
+        Assert.assertTrue(firstOneBasedIndex >= 1, "Expected first index to be one-based and positive.");
+        Assert.assertTrue(secondOneBasedIndex >= 1, "Expected second index to be one-based and positive.");
+        Assert.assertTrue(names.size() >= Math.max(firstOneBasedIndex, secondOneBasedIndex),
+                "Expected enough visible catalog products for the requested comparison indices.");
+
+        List<String> selected = new ArrayList<>();
+        selected.add(names.get(firstOneBasedIndex - 1));
+        selected.add(names.get(secondOneBasedIndex - 1));
+        return selected;
+    }
+
+    public void assertComparisonDestinationForProducts(List<String> productNames) {
+        Assert.assertEquals(productNames.size(), 2, "Expected exactly two product names for the multi-compare assertion.");
+        WaitUtils.waitForCondition(
+                "comparison page becomes visible for two selected products",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Comparison page body");
+                    return url.contains("/comparison")
+                            && body.contains("Product Comparison")
+                            && body.contains("Show differences only")
+                            && productNames.stream().allMatch(body::contains);
+                },
+                "Expected comparison destination to materialize both selected products."
+        );
+
+        String body = UIActions.getText("body", "Comparison page body");
+        for (String productName : productNames) {
+            Assert.assertTrue(body.contains(productName), "Expected product on comparison page: " + productName);
+        }
+    }
+
+    public void assertComparisonRetainsOnlyRemainingProduct(String removedProductName, String remainingProductName) {
+        WaitUtils.waitForCondition(
+                "comparison page retains a single remaining product after targeted removal",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText("body", "Comparison body after targeted removal");
+                    List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Comparison product names after targeted removal");
+                    return url.contains("/comparison")
+                            && body.contains("Product Comparison")
+                            && body.contains("Show differences only")
+                            && body.contains("Clear All")
+                            && !body.contains("No products selected for comparison")
+                            && names.size() == 1
+                            && names.contains(remainingProductName)
+                            && !names.contains(removedProductName);
+                },
+                "Expected targeted comparison removal to keep exactly one remaining product on the comparison page."
+        );
+
+        String body = UIActions.getText("body", "Comparison body after targeted removal");
+        List<String> names = UIActions.getVisibleTexts(CatalogPage.PRODUCT_NAMES, "Comparison product names after targeted removal");
+        Assert.assertEquals(names.size(), 1, "Expected exactly one product to remain after targeted comparison removal.");
+        Assert.assertTrue(names.contains(remainingProductName), "Expected the remaining comparison product to stay visible.");
+        Assert.assertFalse(names.contains(removedProductName), "Expected the removed comparison product to disappear.");
+        Assert.assertFalse(body.contains("No products selected for comparison"), "Expected targeted removal to avoid collapsing into empty-state guidance.");
+    }
+
+    public void assertComparisonShowDifferencesHidesSharedSpecification(List<String> productNames,
+                                                                        String hiddenSharedSpecificationLabel,
+                                                                        String remainingDifferingSpecificationLabel) {
+        Assert.assertEquals(productNames.size(), 2, "Expected exactly two product names for the comparison diff assertion.");
+
+        WaitUtils.waitForCondition(
+                "comparison page is ready for show-differences filtering",
+                () -> {
+                    String body = UIActions.getText("body", "Comparison body before enabling show differences");
+                    return body.contains("Product Comparison")
+                            && body.contains("Show differences only")
+                            && productNames.stream().allMatch(body::contains)
+                            && body.contains(hiddenSharedSpecificationLabel)
+                            && body.contains(remainingDifferingSpecificationLabel);
+                },
+                "Expected comparison page to expose the shared and differing specification rows before diff filtering."
+        );
+
+        UIActions.click(CatalogPage.SHOW_DIFFERENCES_ONLY, "Show differences only");
+
+        WaitUtils.waitForCondition(
+                "show-differences hides the shared specification row",
+                () -> {
+                    String body = UIActions.getText("body", "Comparison body after enabling show differences");
+                    return body.contains("Product Comparison")
+                            && body.contains("Show differences only")
+                            && body.contains(remainingDifferingSpecificationLabel)
+                            && !body.contains(hiddenSharedSpecificationLabel);
+                },
+                "Expected show-differences to remove the shared specification row while preserving a differing row."
+        );
+
+        String body = UIActions.getText("body", "Comparison body after enabling show differences");
+        Assert.assertFalse(body.contains(hiddenSharedSpecificationLabel),
+                "Expected the shared specification row to disappear after enabling show differences.");
+        Assert.assertTrue(body.contains(remainingDifferingSpecificationLabel),
+                "Expected a differing specification row to remain visible after enabling show differences.");
+    }
+
+    public void assertFavoritesPageReturnsToEmptyState(String removedProductName) {
+        WaitUtils.waitForCondition(
+                "favorites page returns to empty state",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = UIActions.getText(AccountPage.FAVORITES_EMPTY_STATE, "Favorites page body");
+                    List<String> names = UIActions.getVisibleTexts(StorefrontPage.PRODUCT_NAME, "Favorite product names after deletion");
+                    return url.contains("/account/favorites")
+                            && body.contains("There are no favorites yet")
+                            && !names.contains(removedProductName);
+                },
+                "Expected favorites page to return to the empty-state message after deletion."
+        );
+    }
+
+    public void assertProfileUpdateSuccessAndPersistence(String firstName,
+                                                         String lastName,
+                                                         String phone,
+                                                         String street,
+                                                         String postalCode,
+                                                         String city,
+                                                         String state,
+                                                         String country) {
+        WaitUtils.waitForCondition(
+                "profile editor remains on the updated state",
+                () -> DriverManager.getEngine().getCurrentUrl().contains("/account/profile")
+                        && firstName.equals(UIActions.getValue(AccountPage.FIRST_NAME, "Profile first name"))
+                        && lastName.equals(UIActions.getValue(AccountPage.LAST_NAME, "Profile last name"))
+                        && phone.equals(UIActions.getValue(AccountPage.PHONE, "Profile phone"))
+                        && street.equals(UIActions.getValue(AccountPage.STREET, "Profile street"))
+                        && postalCode.equals(UIActions.getValue(AccountPage.POSTAL_CODE, "Profile postal code"))
+                        && city.equals(UIActions.getValue(AccountPage.CITY, "Profile city"))
+                        && state.equals(UIActions.getValue(AccountPage.STATE, "Profile state"))
+                        && country.equals(UIActions.getValue(AccountPage.COUNTRY, "Profile country")),
+                "Expected profile update to persist inside the current editor state."
+        );
+
+        WaitUtils.waitForInputValue(AccountPage.FIRST_NAME, "Profile first name", firstName::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.LAST_NAME, "Profile last name", lastName::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.PHONE, "Profile phone", phone::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.STREET, "Profile street", street::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.POSTAL_CODE, "Profile postal code", postalCode::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.CITY, "Profile city", city::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.STATE, "Profile state", state::equals, Duration.ofSeconds(15));
+        WaitUtils.waitForInputValue(AccountPage.COUNTRY, "Profile country", country::equals, Duration.ofSeconds(15));
+    }
+
+    public void assertRedirectedToLoginAfterPasswordChange() {
+        WaitUtils.waitForCondition(
+                "password change redirects to login",
+                () -> DriverManager.getEngine().getCurrentUrl().contains("/auth/login")
+                        && DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON),
+                "Expected password change to force the customer back to the login surface."
+        );
+    }
+
+    public void assertCartQuantityMaterialized(String productName, int expectedQuantity) {
+        String expected = String.valueOf(expectedQuantity);
+        WaitUtils.waitForCondition(
+                "cart badge becomes the requested quantity",
+                () -> expected.equals(UIActions.getText(StorefrontPage.CART_QUANTITY, "Cart quantity badge")),
+                "Expected cart badge to reflect the requested quantity."
+        );
+
+        WaitUtils.waitForCondition(
+                "checkout row materializes the requested quantity",
+                () -> {
+                    String body = UIActions.getText("body", "Checkout body");
+                    String quantity = UIActions.getValue(StorefrontPage.CHECKOUT_PRODUCT_QUANTITY_INPUT, "Checkout product quantity");
+                    return body.contains(productName) && expected.equals(quantity);
+                },
+                "Expected checkout line to materialize the requested quantity for the selected product."
+        );
+    }
+
+    public double readCheckoutUnitPrice() {
+        String unitPrice = UIActions.getText(CheckoutPage.PRODUCT_PRICE, "Checkout unit price");
+        return parseCurrency(unitPrice);
+    }
+
+    public void assertCheckoutQuantityAdjustment(String productName, int expectedQuantity, double unitPrice) {
+        String expected = String.valueOf(expectedQuantity);
+        String expectedLineTotal = String.format(Locale.US, "$%.2f", unitPrice * expectedQuantity);
+
+        WaitUtils.waitForCondition(
+                "checkout quantity edit updates the cart summary",
+                () -> {
+                    String body = UIActions.getText("body", "Checkout body");
+                    String quantity = UIActions.getValue(CheckoutPage.PRODUCT_QUANTITY, "Checkout product quantity");
+                    String badge = UIActions.getText(StorefrontPage.CART_QUANTITY, "Cart quantity badge");
+                    String linePrice = UIActions.getText(CheckoutPage.LINE_PRICE, "Checkout line price");
+                    String cartTotal = UIActions.getText(CheckoutPage.CART_TOTAL, "Checkout cart total");
+                    return body.contains(productName)
+                            && expected.equals(quantity)
+                            && expected.equals(badge)
+                            && linePrice.contains(expectedLineTotal)
+                            && cartTotal.contains(expectedLineTotal);
+                },
+                "Expected checkout quantity edit to update quantity badge and line total."
+        );
+    }
+
+    private double parseCurrency(String rawValue) {
+        String normalized = rawValue.replaceAll("[^0-9.]", "");
+        return Double.parseDouble(normalized);
+    }
+}
