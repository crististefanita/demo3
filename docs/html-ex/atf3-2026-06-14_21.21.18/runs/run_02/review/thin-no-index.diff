+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class MessageValidation {
+
+    private static final String CONTACT_SUCCESS = "Thanks for your message! We will contact you shortly.";
+
+    public void assertContactSuccess() {
+        WaitUtils.waitForCondition(
+                "contact success banner is visible",
+                () -> UIActions.getText("body", "Contact page body").contains(CONTACT_SUCCESS),
+                "Expected contact success banner to appear."
+        );
+    }
+
+    public void assertMessageRowContains(String subject, String messagePreview, String status) {
+        WaitUtils.waitForCondition(
+                "messages page contains the submitted message",
+                () -> {
+                    String body = UIActions.getText("body", "Messages page body");
+                    return body.contains(subject) && body.contains(messagePreview) && body.contains(status);
+                },
+                "Expected messages page to contain submitted message row."
+        );
+
+        String body = UIActions.getText("body", "Messages page body");
+        Assert.assertTrue(body.contains(subject), "Expected messages page to contain subject: " + subject);
+        Assert.assertTrue(body.contains(messagePreview), "Expected messages page to contain message preview: " + messagePreview);
+        Assert.assertTrue(body.contains(status), "Expected messages page to contain status: " + status);
+    }
+
+    public void assertMessageDetailVisible(String subject, String fullMessage, String status) {
+        WaitUtils.waitForCondition(
+                "message detail page materializes the expected thread",
+                () -> {
+                    String body = UIActions.getText("body", "Message detail body");
+                    return body.contains("Back")
+                            && body.contains(subject)
+                            && body.contains(fullMessage)
+                            && body.contains(status)
+                            && body.contains("Replies");
+                },
+                "Expected message detail page to materialize the submitted thread."
+        );
+    }
+
+    public void assertReplyMaterializedAndStatusProgressed(String replyText) {
+        WaitUtils.waitForCondition(
+                "message reply materializes and advances the thread status",
+                () -> {
+                    String body = UIActions.getText("body", "Message thread after reply");
+                    return body.contains("IN_PROGRESS") && body.contains(replyText);
+                },
+                "Expected the reply to materialize and move the thread into IN_PROGRESS."
+        );
+    }
+
+    public void assertMessagesPageContainsAll(String... expectedFragments) {
+        WaitUtils.waitForCondition(
+                "messages page contains all expected fragments",
+                () -> containsAll(UIActions.getText("body", "Messages page body"), expectedFragments),
+                "Expected messages page to contain all requested fragments."
+        );
+
+        String body = UIActions.getText("body", "Messages page body");
+        for (String expectedFragment : expectedFragments) {
+            Assert.assertTrue(body.contains(expectedFragment), "Expected messages page to contain: " + expectedFragment);
+        }
+    }
+
+    public void assertMessageDetailContainsAll(String... expectedFragments) {
+        WaitUtils.waitForCondition(
+                "message detail contains all expected fragments",
+                () -> containsAll(UIActions.getText("body", "Message detail body"), expectedFragments),
+                "Expected message detail to contain all requested fragments."
+        );
+
+        String body = UIActions.getText("body", "Message detail body");
+        for (String expectedFragment : expectedFragments) {
+            Assert.assertTrue(body.contains(expectedFragment), "Expected message detail to contain: " + expectedFragment);
+        }
+    }
+
+    private boolean containsAll(String body, String... expectedFragments) {
+        for (String expectedFragment : expectedFragments) {
+            if (!body.contains(expectedFragment)) {
+                return false;
+            }
+        }
+        return true;
+    }
+}
diff --git a/src/test/java/com/endava/ai/atf/ui/AuthenticatedMessageThreadLifecycleTests.java b/src/test/java/com/endava/ai/atf/ui/AuthenticatedMessageThreadLifecycleTests.java
new file mode 100644
index 0000000..8a08993
--- /dev/null
+++ b/src/test/java/com/endava/ai/atf/ui/AuthenticatedMessageThreadLifecycleTests.java
@@ -0,0 +1,157 @@
+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.MessageService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.AccountValidation;
+import com.endava.ai.ui.validation.MessageValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedMessageThreadLifecycleTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final LoginService loginService = new LoginService();
+    private final AccountValidation accountValidation = new AccountValidation();
+    private final MessageService messageService = new MessageService();
+    private final MessageValidation messageValidation = new MessageValidation();
+
+    @BeforeMethod
+    public void before() {
+        StepLogger.startStep("Authenticated message thread lifecycle preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Run 01: authenticated message reply survives a fresh login inside the thread detail")
+    public void run_01_message_reply_survives_fresh_login_inside_thread_detail() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        String suffix = uniqueSuffix();
+        String subject = "payments";
+        String fullMessage = "codex-" + suffix + "-message-reply-durability-abcdefghijklmnopqrstuvwxyz";
+        String reply = "codex-" + suffix + "-reply-after-boundary";
+
+        registerAndLogin(customer);
+        submitMessage(customer, subject, fullMessage);
+        reopenMessageDetailAfterFreshLogin(customer, subject, fullMessage);
+
+        messageService.replyToCurrentMessage(reply);
+        messageValidation.assertReplyMaterializedAndStatusProgressed(reply);
+
+        reopenMessageDetailAfterFreshLogin(customer, subject, fullMessage);
+        messageValidation.assertMessageDetailContainsAll(subject, fullMessage, reply, "IN_PROGRESS");
+    }
+
+    @Test(description = "Run 02: authenticated message list preserves the progressed thread status after fresh login")
+    public void run_02_message_list_preserves_progressed_thread_status_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        String suffix = uniqueSuffix();
+        String subject = "payments";
+        String fullMessage = "codex-" + suffix + "-message-list-status-abcdefghijklmnopqrstuvwxyz";
+        String preview = fullMessage.substring(0, 40);
+        String reply = "codex-" + suffix + "-reply-status-list";
+
+        registerAndLogin(customer);
+        submitMessage(customer, subject, fullMessage);
+        reopenMessageDetailAfterFreshLogin(customer, subject, fullMessage);
+        messageService.replyToCurrentMessage(reply);
+        messageValidation.assertReplyMaterializedAndStatusProgressed(reply);
+
+        UIActions.clearSession();
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+        messageService.openMessagesDirect();
+        messageValidation.assertMessagesPageContainsAll(subject, preview, "IN_PROGRESS");
+    }
+
+    @Test(description = "Run 03: authenticated customer can retain two separate message rows after fresh login")
+    public void run_03_two_distinct_messages_remain_listed_after_fresh_login() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        String suffix = uniqueSuffix();
+        String firstMessage = "codex-" + suffix + "-first-thread-abcdefghijklmnopqrstuvwxyz";
+        String secondMessage = "codex-" + suffix + "-second-thread-abcdefghijklmnopqrstuvwxyz";
+        String firstPreview = firstMessage.substring(0, 40);
+        String secondPreview = secondMessage.substring(0, 40);
+
+        registerAndLogin(customer);
+        submitMessage(customer, "payments", firstMessage);
+        submitMessage(customer, "warranty", secondMessage);
+
+        UIActions.clearSession();
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+        messageService.openMessagesDirect();
+        messageValidation.assertMessagesPageContainsAll("payments", "warranty", firstPreview, secondPreview, "NEW");
+    }
+
+    @Test(description = "Run 04: authenticated message detail can be reopened after direct messages navigation")
+    public void run_04_message_detail_reopens_after_direct_messages_navigation() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        String suffix = uniqueSuffix();
+        String subject = "payments";
+        String fullMessage = "codex-" + suffix + "-direct-detail-abcdefghijklmnopqrstuvwxyz";
+
+        registerAndLogin(customer);
+        submitMessage(customer, subject, fullMessage);
+
+        messageService.openMessagesDirect();
+        messageService.openFirstMessageDetail();
+        messageValidation.assertMessageDetailContainsAll(subject, fullMessage, "NEW", "Replies");
+    }
+
+    @Test(description = "Run 05: authenticated message thread remains readable after account hub reentry")
+    public void run_05_message_thread_remains_readable_after_account_hub_reentry() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        String suffix = uniqueSuffix();
+        String subject = "payments";
+        String fullMessage = "codex-" + suffix + "-account-hub-reentry-abcdefghijklmnopqrstuvwxyz";
+        String preview = fullMessage.substring(0, 40);
+
+        registerAndLogin(customer);
+        submitMessage(customer, subject, fullMessage);
+
+        UIActions.navigateToRelative("/account");
+        accountValidation.assertAccountHubVisible();
+        messageService.openMessages();
+        messageValidation.assertMessageRowContains(subject, preview, "NEW");
+        messageService.openFirstMessageDetail();
+        messageValidation.assertMessageDetailContainsAll(subject, fullMessage, "NEW", "Replies");
+    }
+
+    private void registerAndLogin(CustomerData customer) {
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+    }
+
+    private void submitMessage(CustomerData customer, String subject, String fullMessage) {
+        messageService.sendMessage(subject, fullMessage);
+        messageValidation.assertContactSuccess();
+        accountValidation.assertAccountIdentityVisible(customer.getFirstName() + " " + customer.getLastName());
+    }
+
+    private void reopenMessageDetailAfterFreshLogin(CustomerData customer, String subject, String fullMessage) {
+        UIActions.clearSession();
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+
+        messageService.openMessagesDirect();
+        messageValidation.assertMessagesPageContainsAll(subject, fullMessage.substring(0, 40));
+        messageService.openFirstMessageDetail();
+        messageValidation.assertMessageDetailContainsAll(subject, fullMessage);
+    }
+
+    private String uniqueSuffix() {
+        return String.valueOf(System.currentTimeMillis()).substring(6);
+    }
+}
