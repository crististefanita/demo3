+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.pages.ContactPage;
+import com.endava.ai.ui.pages.MessagePage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class MessageService {
+
+    public void openContact() {
+        UIActions.navigateToRelative("/contact");
+        WaitUtils.waitForVisible(ContactPage.SUBJECT);
+    }
+
+    public void sendMessage(String subject, String message) {
+        openContact();
+        UIActions.select(ContactPage.SUBJECT, "Contact subject", subject);
+        UIActions.type(ContactPage.MESSAGE, "Contact message", message);
+        UIActions.click(ContactPage.SUBMIT, "Submit contact message");
+    }
+
+    public void submitEmptyMessageForm() {
+        openContact();
+        UIActions.click(ContactPage.SUBMIT, "Submit empty contact message");
+    }
+
+    public void openMessages() {
+        UIActions.navigateToRelative("/account");
+        WaitUtils.waitForVisible(AccountPage.NAV_MESSAGES);
+        UIActions.click(AccountPage.NAV_MESSAGES, "Messages");
+        WaitUtils.waitForUrlContains("/account/messages");
+    }
+
+    public void openMessagesDirect() {
+        UIActions.navigateToRelative("/account/messages");
+        WaitUtils.waitForUrlContains("/account/messages");
+        WaitUtils.waitForVisible(MessagePage.MESSAGE_ROWS);
+    }
+
+    public void openFirstMessageDetail() {
+        UIActions.click(MessagePage.FIRST_MESSAGE_DETAIL_LINK, "First message detail");
+        WaitUtils.waitForVisible(MessagePage.DETAIL_BACK_LINK);
+    }
+
+    public void replyToCurrentMessage(String reply) {
+        UIActions.type(MessagePage.REPLY_MESSAGE, "Message reply", reply);
+        UIActions.click(MessagePage.REPLY_SUBMIT, "Reply");
+    }
+}
diff --git a/src/main/java/com/endava/ai/ui/validation/MessageValidation.java b/src/main/java/com/endava/ai/ui/validation/MessageValidation.java
