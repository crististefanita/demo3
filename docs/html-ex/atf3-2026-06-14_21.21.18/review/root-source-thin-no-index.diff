+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import org.testng.annotations.Test;
+
+public class AuthenticatedSecurityDurabilityClosureTests extends AuthenticatedSecurityFlowSupport {
+
+    @Test(description = "Run 01: claimed profile edits still snap back to the original values after TOTP enrollment and challenge relogin")
+    public void run_01_claimed_profile_edits_still_snap_back_to_the_original_values_after_totp_enrollment_and_challenge_relogin() {
+        CustomerData customer = freshCustomer();
+
+        registerAndLogin(customer);
+
+        accountService.openProfile();
+        accountService.updateProfile("Mirela", "Secure", "0710000011", "Audit Street 21", "541001", "Suceava", "SV", "Romania");
+        securityValidation.assertTotpEnrollmentVisible();
+        String secret = accountService.readTotpSecret();
+        accountService.verifyTotp(com.endava.ai.ui.utils.TotpGenerator.currentCode(secret));
+        accountValidation.assertProfileEditorReady();
