+package com.endava.ai.ui.validation;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class PaymentMethodValidation {
+
+    public void assertPaymentConfirmationBlocked(String description) {
+        validate(description, () -> WaitUtils.waitForCondition(
+                description,
+                () -> !DriverManager.getEngine().isEnabled(CheckoutPage.FINISH),
+                "Expected payment confirmation to remain blocked."
+        ));
+    }
+
+    public void assertPaymentConfirmationEnabled(String description) {
+        validate(description, () -> WaitUtils.waitForCondition(
+                description,
+                () -> DriverManager.getEngine().isEnabled(CheckoutPage.FINISH),
+                "Expected payment confirmation to become enabled."
+        ));
+    }
+
+    public void assertBnplInstallmentsVisible() {
+        assertVisible(CheckoutPage.MONTHLY_INSTALLMENTS, "BNPL monthly installments");
+    }
+
+    public void assertCreditCardFieldsVisible() {
+        assertVisible(CheckoutPage.CREDIT_CARD_NUMBER, "Credit card number");
+        assertVisible(CheckoutPage.EXPIRATION_DATE, "Credit card expiration date");
+        assertVisible(CheckoutPage.CVV, "Credit card CVV");
+        assertVisible(CheckoutPage.CARD_HOLDER_NAME, "Credit card holder name");
+    }
+
+    public void assertGiftCardFieldsVisible() {
+        assertVisible(CheckoutPage.GIFT_CARD_NUMBER, "Gift card number");
+        assertVisible(CheckoutPage.VALIDATION_CODE, "Gift card validation code");
+    }
+
+    public void assertBankTransferFieldsVisible() {
+        assertVisible(CheckoutPage.BANK_NAME, "Bank transfer bank name");
+        assertVisible(CheckoutPage.ACCOUNT_NAME, "Bank transfer account name");
+        assertVisible(CheckoutPage.ACCOUNT_NUMBER, "Bank transfer account number");
+    }
+
+    public void assertCreditCardFieldsHiddenAfterSwitch() {
+        validate("credit-card fields disappear after method switch", () -> {
+            Assert.assertFalse(safeVisible(CheckoutPage.CREDIT_CARD_NUMBER), "Expected credit card number field to disappear after switching methods.");
+            Assert.assertFalse(safeVisible(CheckoutPage.EXPIRATION_DATE), "Expected credit card expiration field to disappear after switching methods.");
+            Assert.assertFalse(safeVisible(CheckoutPage.CVV), "Expected credit card CVV field to disappear after switching methods.");
+            Assert.assertFalse(safeVisible(CheckoutPage.CARD_HOLDER_NAME), "Expected credit card holder field to disappear after switching methods.");
+        });
+    }
+
+    private void assertVisible(String selector, String description) {
+        validate(description + " is visible", () -> WaitUtils.waitForCondition(
+                description + " is visible",
+                () -> safeVisible(selector),
+                "Expected " + description + " to become visible."
+        ));
+    }
+
+    private boolean safeVisible(String selector) {
+        try {
+            return DriverManager.getEngine().isVisible(selector);
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+
+    private void validate(String title, Runnable assertion) {
+        StepLogger.startStep("Validate: " + title);
+        try {
+            assertion.run();
+            StepLogger.pass("Validated");
+        } catch (Throwable t) {
+            StepLogger.fail("Validation failed: " + title, t);
+            throw t;
+        }
+    }
+}
