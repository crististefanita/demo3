+package com.endava.ai.atf.ui;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.LoginService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.utils.TotpGenerator;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.AccountValidation;
+import com.endava.ai.ui.validation.LoginValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import com.endava.ai.ui.validation.SecurityValidation;
+import org.testng.annotations.BeforeMethod;
+
+public abstract class AuthenticatedSecurityFlowSupport extends BaseTestUI {
+
+    protected final RegistrationService registrationService = new RegistrationService();
+    protected final RegistrationValidation registrationValidation = new RegistrationValidation();
+    protected final LoginService loginService = new LoginService();
+    protected final LoginValidation loginValidation = new LoginValidation();
+    protected final AccountService accountService = new AccountService();
+    protected final AccountValidation accountValidation = new AccountValidation();
+    protected final SecurityValidation securityValidation = new SecurityValidation();
+
+    @BeforeMethod
+    public void resetSecurityFlow() {
+        StepLogger.startStep("Authenticated security frontier preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Ready");
+    }
+
+    protected CustomerData freshCustomer() {
+        return CustomerDataFactory.validCustomer();
+    }
+
+    protected void registerAndLogin(CustomerData customer) {
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+
+        loginService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertAccountHubVisible();
+    }
+
+    protected void clearSessionAndLogin(String email, String password) {
+        UIActions.clearSession();
+        loginService.login(email, password);
+    }
+
+    protected String openProfileAndReadTotpSecret() {
+        accountService.openProfile();
+        securityValidation.assertTotpEnrollmentVisible();
+        return accountService.readTotpSecret();
+    }
+
+    protected String enrollTotpOnCurrentProfile() {
+        String secret = openProfileAndReadTotpSecret();
+        accountService.verifyTotp(TotpGenerator.currentCode(secret));
+        accountValidation.assertProfileEditorReady();
+        return secret;
+    }
+
+    protected void submitLiveTotpChallenge(String secret) {
+        loginService.submitTotpCode(TotpGenerator.currentCode(secret));
+        accountValidation.assertAccountHubVisible();
+    }
+}
