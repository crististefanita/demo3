@@ -0,0 +1,110 @@
+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+import java.time.Duration;
+
+public final class AccountValidation {
+
+    public void assertAccountHubVisible() {
+        String outcome = WaitUtils.waitUntil(
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    boolean profileVisible = safeVisible(AccountPage.NAV_PROFILE);
+                    boolean favoritesVisible = safeVisible(AccountPage.NAV_FAVORITES);
+                    boolean invoicesVisible = safeVisible(AccountPage.NAV_INVOICES);
+                    boolean messagesVisible = safeVisible(AccountPage.NAV_MESSAGES);
+
+                    if (url.contains("/account")
+                            && profileVisible
+                            && favoritesVisible
+                            && invoicesVisible
+                            && messagesVisible) {
+                        return "account-hub";
+                    }
+
+                    return "pending";
+                },
+                value -> !"pending".equals(value),
+                Duration.ofSeconds(20),
+                Duration.ofMillis(250)
+        );
+
+        if (!"account-hub".equals(outcome)) {
+            throw new AssertionError(
+                    "Expected authenticated account hub to become visible, but current URL is: "
+                            + DriverManager.getEngine().getCurrentUrl()
+            );
+        }
+    }
+
+    public void assertProfileEditorReady() {
+        WaitUtils.waitForUrlContains("/account/profile");
+        WaitUtils.waitForVisible(AccountPage.FIRST_NAME);
+        WaitUtils.waitForVisible(AccountPage.LAST_NAME);
+        WaitUtils.waitForVisible(AccountPage.EMAIL);
+        WaitUtils.waitForVisible(AccountPage.PHONE);
+        WaitUtils.waitForVisible(AccountPage.STREET);
+        WaitUtils.waitForVisible(AccountPage.POSTAL_CODE);
+        WaitUtils.waitForVisible(AccountPage.CITY);
+        WaitUtils.waitForVisible(AccountPage.STATE);
+        WaitUtils.waitForVisible(AccountPage.COUNTRY);
+        WaitUtils.waitForVisible(AccountPage.UPDATE_PROFILE_BUTTON);
+        WaitUtils.waitForVisible(AccountPage.CURRENT_PASSWORD);
+        WaitUtils.waitForVisible(AccountPage.NEW_PASSWORD);
+        WaitUtils.waitForVisible(AccountPage.NEW_PASSWORD_CONFIRM);
+        WaitUtils.waitForVisible(AccountPage.CHANGE_PASSWORD_BUTTON);
+
+        Assert.assertTrue(
+                DriverManager.getEngine().getCurrentUrl().contains("/account/profile"),
+                "Expected to remain on /account/profile, but was: " + DriverManager.getEngine().getCurrentUrl()
+        );
+    }
+
+    public void assertProfileValues(String firstName,
+                                    String lastName,
+                                    String phone,
+                                    String street,
+                                    String postalCode,
+                                    String city,
+                                    String state,
+                                    String country) {
+        WaitUtils.waitForInputValue(AccountPage.FIRST_NAME, "Profile first name", firstName::equals);
+        WaitUtils.waitForInputValue(AccountPage.LAST_NAME, "Profile last name", lastName::equals);
+        WaitUtils.waitForInputValue(AccountPage.PHONE, "Profile phone", phone::equals);
+        WaitUtils.waitForInputValue(AccountPage.STREET, "Profile street", street::equals);
+        WaitUtils.waitForInputValue(AccountPage.POSTAL_CODE, "Profile postal code", postalCode::equals);
+        WaitUtils.waitForInputValue(AccountPage.CITY, "Profile city", city::equals);
+        WaitUtils.waitForInputValue(AccountPage.STATE, "Profile state", state::equals);
+        WaitUtils.waitForInputValue(AccountPage.COUNTRY, "Profile country", country::equals);
+    }
+
+    public void assertAccountIdentityVisible(String expectedFullName) {
+        WaitUtils.waitForCondition(
+                "account nav identity reflects the expected full name",
+                () -> {
+                    String menuText = UIActions.getText(AccountPage.NAV_MENU, "Account nav menu");
+                    return menuText.contains(expectedFullName);
+                },
+                "Expected the authenticated account identity chip to show: " + expectedFullName
+        );
+    }
+
+    public void assertSuccessAlertContains(String expectedText) {
+        WaitUtils.waitForVisible(AccountPage.SUCCESS_ALERT);
+        String alert = UIActions.getText(AccountPage.SUCCESS_ALERT, "Success alert");
+        Assert.assertTrue(alert.contains(expectedText), "Expected success alert to contain: " + expectedText);
+    }
+
+    private boolean safeVisible(String locator) {
+        try {
+            return DriverManager.getEngine().isVisible(locator);
+        } catch (Exception ignored) {
+            return false;
+        }
+    }
+}
