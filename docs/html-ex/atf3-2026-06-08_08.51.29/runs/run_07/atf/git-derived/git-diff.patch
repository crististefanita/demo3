+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.FavoritesPage;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+import java.time.Duration;
+import java.util.List;
+
+public final class FavoritesValidation {
+
+    private static final String EMPTY_STATE_TEXT =
+            "There are no favorites yet. In order to add favorites, please go to the product listing and mark some products as your favorite.";
+
+    public void assertOnFavoritesPage() {
+        WaitUtils.waitForCondition(
+                "favorites page is visible",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String title = safeText(FavoritesPage.PAGE_TITLE);
+                    return url.contains("/account/favorites") && "Favorites".equals(title);
+                },
+                "Expected favorites page, but URL is: " + DriverManager.getEngine().getCurrentUrl()
+        );
+    }
+
+    public void assertContainsProduct(String expectedProductName) {
+        assertOnFavoritesPage();
+
+        List<String> names = WaitUtils.waitUntil(
+                () -> DriverManager.getEngine().getTexts(FavoritesPage.PRODUCT_NAMES),
+                values -> values.stream().anyMatch(expectedProductName::equals),
+                Duration.ofSeconds(20),
+                Duration.ofMillis(250)
+        );
+
+        Assert.assertTrue(
+                names.stream().anyMatch(expectedProductName::equals),
+                "Expected favorites to contain '" + expectedProductName + "', but found: " + names
+        );
+    }
+
+    public void assertEmptyStateVisible() {
+        assertOnFavoritesPage();
+
+        WaitUtils.waitForCondition(
+                "favorites empty state",
+                () -> safeText("body").contains(EMPTY_STATE_TEXT),
+                "Expected favorites empty state to be visible."
+        );
+
+        Assert.assertTrue(
+                safeText("body").contains(EMPTY_STATE_TEXT),
+                "Expected favorites empty state to be visible."
+        );
+    }
+
+    public void assertFavoritesSurfaceUnavailable() {
+        WaitUtils.waitForCondition(
+                "favorites surface unavailable",
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String title = safeText(FavoritesPage.PAGE_TITLE);
+                    return !url.contains("/account/favorites") || !"Favorites".equals(title);
+                },
+                "Expected favorites surface to stay unavailable, but URL is: "
+                        + DriverManager.getEngine().getCurrentUrl()
+                        + " and title was: "
+                        + safeText(FavoritesPage.PAGE_TITLE)
+        );
+
+        String url = DriverManager.getEngine().getCurrentUrl();
+        String title = safeText(FavoritesPage.PAGE_TITLE);
+        Assert.assertFalse(
+                url.contains("/account/favorites") && "Favorites".equals(title),
+                "Expected favorites surface to stay unavailable, but URL is: " + url + " and title was: " + title
+        );
+    }
+
+    private String safeText(String locator) {
+        try {
+            return DriverManager.getEngine().getText(locator);
+        } catch (Exception ignored) {
+            return "";
+        }
+    }
+}

diff --git a/src/test/java/com/endava/ai/atf/ui/AccountPasswordFavoritesTransitionTests.java b/src/test/java/com/endava/ai/atf/ui/AccountPasswordFavoritesTransitionTests.java
