+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.FavoritesPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class FavoritesService {
+
+    public void openFavorites() {
+        UIActions.navigateToRelative("/account/favorites");
+        WaitUtils.waitForVisible(FavoritesPage.PAGE_TITLE);
+    }
+
+    public void openFavoritesRouteOnly() {
+        UIActions.navigateToRelative("/account/favorites");
+    }
+
+    public void removeFirstFavorite() {
+        WaitUtils.waitForVisible(FavoritesPage.DELETE_BUTTON);
+        UIActions.click(FavoritesPage.DELETE_BUTTON, "Delete first favorite");
+    }
+}

