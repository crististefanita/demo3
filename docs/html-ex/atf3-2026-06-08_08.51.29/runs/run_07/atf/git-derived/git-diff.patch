+package com.endava.ai.atf.ui;
+
+import com.endava.ai.atf.ui.support.ProtectedAccountSeed;
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.pages.ProductPage;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.AuthenticationService;
+import com.endava.ai.ui.service.FavoritesService;
+import com.endava.ai.ui.service.ProductService;
+import com.endava.ai.ui.validation.AuthenticationValidation;
+import com.endava.ai.ui.validation.FavoritesValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AccountPasswordFavoritesTransitionTests extends BaseTestUI {
+
+    private final AuthenticationService authenticationService = new AuthenticationService();
+    private final AuthenticationValidation authenticationValidation = new AuthenticationValidation();
+    private final AccountService accountService = new AccountService();
+    private final ProductService productService = new ProductService();
+    private final FavoritesService favoritesService = new FavoritesService();
+    private final FavoritesValidation favoritesValidation = new FavoritesValidation();
+
+    @BeforeMethod
+    public void before() {
+        authenticationService.clearSession();
+        StepLogger.startStep("Password favorites transition preconditions");
+        StepLogger.pass("Ready");
+    }
+
+    @Test(description = "Positive: changed password rejects the old credential and reopens the same favorites state with the new credential")
+    public void changed_password_can_reopen_the_same_favorites_state_with_the_new_credential() {
+        CustomerData customer = ProtectedAccountSeed.mutationCustomer();
+        String oldPassword = customer.getPassword();
+        String newPassword = CustomerDataFactory.newStrongPassword();
+
+        try {
+            seedFavoriteAndChangePassword(customer, oldPassword, newPassword);
+
+            authenticationService.clearSession();
+            authenticationService.openLogin();
+            authenticationService.login(customer.getEmail(), oldPassword);
+            authenticationValidation.assertLoginErrorContains("Invalid email or password");
+
+            authenticationService.clearSession();
+            loginIntoFavorites(customer.getEmail(), newPassword);
+            favoritesValidation.assertContainsProduct(ProductPage.COMBINATION_PLIERS_NAME);
+        } finally {
+            authenticationService.clearSession();
+        }
+    }
+
+    @Test(description = "Negative: old credential is rejected when reopening the same favorites state after the claimed password change")
+    public void old_credential_is_rejected_when_reopening_the_same_favorites_state_after_the_claimed_change() {
+        CustomerData customer = ProtectedAccountSeed.mutationCustomer();
+        String oldPassword = customer.getPassword();
+        String newPassword = CustomerDataFactory.newStrongPassword();
+
+        try {
+            seedFavoriteAndChangePassword(customer, oldPassword, newPassword);
+
+            authenticationService.clearSession();
+            authenticationService.openLogin();
+            authenticationService.login(customer.getEmail(), oldPassword);
+            authenticationValidation.assertLoginErrorContains("Invalid email or password");
+        } finally {
+            authenticationService.clearSession();
+        }
+    }
+
+    @Test(description = "Negative: the same-session favorites surface does not reopen after the claimed password change")
+    public void same_session_favorites_surface_does_not_reopen_after_the_claimed_change() {
+        CustomerData customer = ProtectedAccountSeed.mutationCustomer();
+        String oldPassword = customer.getPassword();
+        String newPassword = CustomerDataFactory.newStrongPassword();
+
+        try {
+            loginIntoProfile(customer.getEmail(), oldPassword);
+            productService.openCombinationPliers();
+            productService.addCurrentProductToFavorites();
+            favoritesService.openFavorites();
+            favoritesValidation.assertContainsProduct(ProductPage.COMBINATION_PLIERS_NAME);
+
+            accountService.openProfile();
+            accountService.changePassword(oldPassword, newPassword);
+
+            favoritesService.openFavoritesRouteOnly();
+            favoritesValidation.assertFavoritesSurfaceUnavailable();
+        } finally {
+            authenticationService.clearSession();
+        }
+    }
+
+    @Test(description = "Negative: favorite removal after the claimed password change is followed by new-credential rejection on fresh login")
+    public void favorite_removal_after_the_claimed_change_is_followed_by_new_credential_rejection() {
+        CustomerData customer = ProtectedAccountSeed.mutationCustomer();
+        String oldPassword = customer.getPassword();
+        String newPassword = CustomerDataFactory.newStrongPassword();
+
+        try {
+            seedFavoriteAndChangePassword(customer, oldPassword, newPassword);
+
+            favoritesService.openFavorites();
+            favoritesValidation.assertContainsProduct(ProductPage.COMBINATION_PLIERS_NAME);
+            favoritesService.removeFirstFavorite();
+            favoritesValidation.assertEmptyStateVisible();
+
+            authenticationService.clearSession();
+            authenticationService.openLogin();
+            authenticationService.login(customer.getEmail(), newPassword);
+            authenticationValidation.assertLoginErrorContains("Invalid email or password");
+        } finally {
+            authenticationService.clearSession();
+        }
+    }
+
+    private void seedFavoriteAndChangePassword(CustomerData customer, String oldPassword, String newPassword) {
+        loginIntoProfile(customer.getEmail(), oldPassword);
+        productService.openCombinationPliers();
+        productService.addCurrentProductToFavorites();
+        favoritesService.openFavorites();
+        favoritesValidation.assertContainsProduct(ProductPage.COMBINATION_PLIERS_NAME);
+        accountService.openProfile();
+        accountService.changePassword(oldPassword, newPassword);
+    }
+
+    private void loginIntoProfile(String email, String password) {
+        authenticationService.openLogin();
+        authenticationService.login(email, password);
+        authenticationValidation.assertOnAccountOverview();
+        accountService.openProfile();
+    }
+
+    private void loginIntoFavorites(String email, String password) {
+        authenticationService.openLogin();
+        authenticationService.login(email, password);
+        authenticationValidation.assertOnAccountOverview();
+        favoritesService.openFavorites();
+    }
+}

