+import com.endava.ai.ui.service.ProductService;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.CommerceValidation;
+import org.testng.annotations.BeforeMethod;
+
+public abstract class CommerceUiTestBase extends BaseTestUI {
+
+    protected final CatalogService catalog = new CatalogService();
+    protected final ProductService product = new ProductService();
+    protected final CartService cart = new CartService();
+    protected final ContactService contact = new ContactService();
+    protected final CommerceValidation validation = new CommerceValidation();
+
+    @BeforeMethod(alwaysRun = true)
+    public void resetCommerceSession() {
+        try {
+            UIActions.clearSession();
+        } catch (Throwable ignored) {
+            // The first test method can run before a page exists; navigation below will create a clean page.
+        }
+        catalog.openHome();
+    }
+
+    protected String currentUrl() {
+        return DriverManager.getEngine().getCurrentUrl();
+    }
+
+    protected void openGuestIdentityWithProduct() {
+        catalog.openFirstProduct();
+        product.addCurrentProductToCart();
+        catalog.openCart();
+        cart.proceedFromCart();
+        cart.chooseGuestCheckout();
+    }
+
+    protected void openGuestBillingAddress() {
+        openGuestIdentityWithProduct();
+        cart.fillGuestIdentity("codex.guest@example.com", "Codex", "Guest");
+        cart.submitGuestIdentity();
+        cart.proceedFromGuestIdentity();
+    }
+
+    protected void openGuestPayment() {
+        openGuestBillingAddress();
+        cart.fillBillingAddress();
+        cart.proceedFromBilling();
+    }
+
+    protected void openGuestPaymentSuccess() {
+        openGuestPayment();
+        cart.chooseCashOnDelivery();
+        cart.confirmPayment();
+    }
+}

