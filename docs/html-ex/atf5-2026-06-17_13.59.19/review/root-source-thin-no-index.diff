+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.CatalogPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class CatalogService {
+
+    public void openHome() {
+        UIActions.navigateToRelative("/");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public void search(String term) {
+        UIActions.type(CatalogPage.SEARCH_QUERY, "Search", term);
+        UIActions.click(CatalogPage.SEARCH_SUBMIT, "Search");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_NAME);
+    }
+
+    public void resetSearch() {
+        UIActions.click(CatalogPage.SEARCH_RESET, "Reset search");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public void sortBy(String visibleText) {
+        UIActions.select(CatalogPage.SORT, "Sort", visibleText);
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public void openFirstProduct() {
+        UIActions.click(CatalogPage.PRODUCT_CARD, "First visible product");
+        WaitUtils.waitForVisible(com.endava.ai.ui.pages.ProductPage.NAME);
+    }
+
+    public void openHammerProduct() {
+        search("Hammer");
+        UIActions.click(CatalogPage.PRODUCT_CARD, "First hammer product");
+        WaitUtils.waitForVisible(com.endava.ai.ui.pages.ProductPage.NAME);
+    }
+
+    public void toggleEcoFilter() {
+        UIActions.click(CatalogPage.ECO_FILTER, "Eco-friendly filter");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public void openHandToolsFromMenu() {
+        UIActions.click(CatalogPage.NAV_HAND_TOOLS, "Hand Tools category");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public void openCart() {
+        UIActions.click(CatalogPage.NAV_CART, "Cart");
+        WaitUtils.waitForVisible(com.endava.ai.ui.pages.CartPage.PRODUCT_TITLE);
+    }
+
+    public void openSignIn() {
+        UIActions.click(CatalogPage.NAV_SIGN_IN, "Sign in");
+        WaitUtils.waitForUrlContains("/auth/login");
+    }
+
+    public String visibleProductNames() {
+        return UIActions.getText(CatalogPage.PRODUCT_NAME, "Visible product names");
+    }
+
+    public String visiblePrices() {
+        return UIActions.getText(CatalogPage.PRODUCT_PRICE, "Visible prices");
+    }
+}

