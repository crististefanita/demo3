+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.pages.CartPage;
+import com.endava.ai.ui.pages.CatalogPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class CartService {
+
+    public void proceedFromCart() {
+        UIActions.click(CartPage.PROCEED_CART, "Proceed from cart");
+        WaitUtils.waitForVisible(CartPage.GUEST_TAB);
+    }
+
+    public void chooseGuestCheckout() {
+        UIActions.click(CartPage.GUEST_TAB, "Continue as Guest tab");
+        WaitUtils.waitForVisible(CartPage.GUEST_EMAIL);
+    }
+
+    public void fillGuestIdentity(String email, String firstName, String lastName) {
+        UIActions.type(CartPage.GUEST_EMAIL, "Guest email", email);
+        UIActions.type(CartPage.GUEST_FIRST_NAME, "Guest first name", firstName);
+        UIActions.type(CartPage.GUEST_LAST_NAME, "Guest last name", lastName);
+    }
+
+    public void submitGuestIdentity() {
+        UIActions.click(CartPage.GUEST_SUBMIT, "Continue as Guest");
+        WaitUtils.waitForVisible(CartPage.PROCEED_GUEST_IDENTITY);
+    }
+
+    public void submitGuestIdentityWithoutProgressWait() {
+        UIActions.click(CartPage.GUEST_SUBMIT, "Continue as Guest");
+    }
+
+    public void proceedFromGuestIdentity() {
+        UIActions.click(CartPage.PROCEED_GUEST_IDENTITY, "Proceed from guest identity");
+        WaitUtils.waitForVisible(CartPage.COUNTRY);
+    }
+
+    public void fillBillingAddress() {
+        UIActions.select(CartPage.COUNTRY, "Country", "Romania");
+        UIActions.type(CartPage.POSTAL_CODE, "Postal code", "010101");
+        UIActions.type(CartPage.HOUSE_NUMBER, "House number", "12");
+        UIActions.type(CartPage.STREET, "Street", "Codex Street");
+        UIActions.type(CartPage.CITY, "City", "Bucharest");
+        UIActions.type(CartPage.STATE, "State", "Bucharest");
+    }
+
+    public void proceedFromBilling() {
+        UIActions.click(CartPage.PROCEED_ADDRESS, "Proceed from billing");
+        WaitUtils.waitForVisible(CartPage.PAYMENT_METHOD);
+    }
+
+    public void chooseCashOnDelivery() {
+        UIActions.select(CartPage.PAYMENT_METHOD, "Payment method", "Cash on Delivery");
+        WaitUtils.waitForVisible(CartPage.FINISH);
+    }
+
+    public void choosePaymentMethod(String paymentMethod) {
+        UIActions.select(CartPage.PAYMENT_METHOD, "Payment method", paymentMethod);
+        WaitUtils.waitForVisible(CartPage.FINISH);
+    }
+
+    public void confirmPayment() {
+        UIActions.click(CartPage.FINISH, "Confirm payment");
+        WaitUtils.waitForVisible(CartPage.PAYMENT_SUCCESS_MESSAGE);
+    }
+
+    public void continueShopping() {
+        UIActions.click(CartPage.CONTINUE_SHOPPING, "Continue shopping");
+        WaitUtils.waitForUrlContains("/");
+        WaitUtils.waitForVisible(CatalogPage.PRODUCT_CARD);
+    }
+
+    public String title() {
+        return UIActions.getText(CartPage.PRODUCT_TITLE, "Cart product title");
+    }
+
+    public String quantity() {
+        return UIActions.getValue(CartPage.PRODUCT_QUANTITY, "Cart quantity");
+    }
+
+    public String productPrice() {
+        return UIActions.getText(CartPage.PRODUCT_PRICE, "Cart product price");
+    }
+
+    public String linePrice() {
+        return UIActions.getText(CartPage.LINE_PRICE, "Cart line price");
+    }
+
+    public String total() {
+        return UIActions.getText(CartPage.CART_TOTAL, "Cart total");
+    }
+
+    public String guestEmail() {
+        return UIActions.getValue(CartPage.GUEST_EMAIL, "Guest email");
+    }
+
+    public String guestFirstName() {
+        return UIActions.getValue(CartPage.GUEST_FIRST_NAME, "Guest first name");
+    }
+
+    public String guestLastName() {
+        return UIActions.getValue(CartPage.GUEST_LAST_NAME, "Guest last name");
+    }
+
+    public String country() {
+        return UIActions.getValue(CartPage.COUNTRY, "Billing country");
+    }
+
+    public String postalCode() {
+        return UIActions.getValue(CartPage.POSTAL_CODE, "Billing postal code");
+    }
+
+    public String houseNumber() {
+        return UIActions.getValue(CartPage.HOUSE_NUMBER, "Billing house number");
+    }
+
+    public String street() {
+        return UIActions.getValue(CartPage.STREET, "Billing street");
+    }
+
+    public String city() {
+        return UIActions.getValue(CartPage.CITY, "Billing city");
+    }
+
+    public String state() {
+        return UIActions.getValue(CartPage.STATE, "Billing state");
+    }
+
+    public String paymentMethodOptions() {
+        return UIActions.getText(CartPage.PAYMENT_METHOD, "Payment method options");
+    }
+
+    public String paymentMethod() {
+        return UIActions.getValue(CartPage.PAYMENT_METHOD, "Selected payment method");
+    }
+
+    public String paymentSuccessMessage() {
+        return UIActions.getText(CartPage.PAYMENT_SUCCESS_MESSAGE, "Payment success message");
+    }
+
+    public String pageText() {
+        return UIActions.getText(CartPage.BODY, "Checkout page text");
+    }
+}

