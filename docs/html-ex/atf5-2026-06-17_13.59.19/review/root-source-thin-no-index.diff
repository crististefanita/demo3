+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.CatalogPage;
+import com.endava.ai.ui.pages.ProductPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class ProductService {
+
+    public void addCurrentProductToCart() {
+        UIActions.click(ProductPage.ADD_TO_CART, "Add to cart");
+        WaitUtils.waitForVisible(CatalogPage.CART_QUANTITY);
+    }
+
+    public void addCurrentProductQuantityToCart(int quantity) {
+        for (int i = 1; i < quantity; i++) {
+            UIActions.click(ProductPage.INCREASE_QUANTITY, "Increase quantity");
+        }
+        WaitUtils.waitForInputValue(ProductPage.QUANTITY, "Product quantity", value -> value.equals(String.valueOf(quantity)));
+        addCurrentProductToCart();
+    }
+
+    public void decreaseQuantity() {
+        UIActions.click(ProductPage.DECREASE_QUANTITY, "Decrease quantity");
+    }
+
+    public void addToFavorites() {
+        UIActions.click(ProductPage.ADD_TO_FAVORITES, "Add to favourites");
+        WaitUtils.waitForCondition(
+                "favorites mutation feedback is visible",
+                () -> {
+                    String bodyText = DriverManager.getEngine().getText("body");
+                    return bodyText.contains("Product added to your favorites list.")
+                            || bodyText.contains("Product already in your favorites list.")
+                            || bodyText.contains("Unauthorized, can not add product to your favorite list.");
+                },
+                "Expected favorites action to publish a visible outcome."
+        );
+    }
+
+    public void addToCompare() {
+        UIActions.click(ProductPage.ADD_TO_COMPARE, "Add to compare");
+    }
+
+    public void openFirstRelatedProduct() {
+        UIActions.click(ProductPage.RELATED_PRODUCT, "First related product");
+        WaitUtils.waitForVisible(ProductPage.NAME);
+    }
+
+    public String name() {
+        return UIActions.getText(ProductPage.NAME, "Product name");
+    }
+
+    public String price() {
+        return UIActions.getText(ProductPage.UNIT_PRICE, "Unit price");
+    }
+
+    public String description() {
+        return UIActions.getText(ProductPage.DESCRIPTION, "Product description");
+    }
+
+    public String specs() {
+        return UIActions.getText(ProductPage.PRODUCT_SPECS, "Product specs");
+    }
+
+    public String quantity() {
+        return UIActions.getValue(ProductPage.QUANTITY, "Quantity");
+    }
+
+    public String co2Rating() {
+        return UIActions.getText(ProductPage.CO2_RATING, "CO2 rating");
+    }
+
+    public String relatedProducts() {
+        return UIActions.getText(ProductPage.RELATED_PRODUCT, "Related products");
+    }
+
+    public String pageText() {
+        return UIActions.getText("body", "Product page text");
+    }
+}

