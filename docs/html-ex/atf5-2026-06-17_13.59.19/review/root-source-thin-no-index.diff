+package com.endava.ai.atf.ui.commerce;
+
+import com.endava.ai.ui.pages.CartPage;
+import org.testng.Assert;
+import org.testng.annotations.Test;
+
+public class GuestIdentityToBillingOwnershipTests extends CommerceUiTestBase {
+
+    @Test
+    public void guest_identity_is_acknowledged_before_billing_ownership() {
+        openGuestIdentityWithProduct();
+        cart.fillGuestIdentity("codex.guest@example.com", "Codex", "Guest");
+        cart.submitGuestIdentity();
+
+        validation.assertPageTextContains(cart.pageText(), "Continuing as guest: Codex Guest (codex.guest@example.com)");
+    }
+
+    @Test
+    public void guest_identity_requires_explicit_business_progression_to_billing() {
+        openGuestIdentityWithProduct();
+        cart.fillGuestIdentity("codex.progression@example.com", "Guest", "Buyer");
+        cart.submitGuestIdentity();
+
+        validation.assertVisible(CartPage.PROCEED_GUEST_IDENTITY, "Guest-to-billing proceed action");
+        validation.assertBillingAddressNotVisible();
+    }
+
+    @Test
+    public void billing_address_becomes_visible_after_guest_progression() {
+        openGuestBillingAddress();
+
+        validation.assertBillingAddressVisible();
+    }
+
+    @Test
+    public void payment_is_not_visible_before_address_is_owned() {
+        openGuestBillingAddress();
+
+        validation.assertPaymentHidden();
+    }
+
+    @Test
+    public void cart_product_context_survives_guest_identity_progression() {
+        openGuestBillingAddress();
+
+        validation.assertTextNotBlank(cart.title(), "Cart product title retained during guest checkout");
+        Assert.assertEquals(cart.quantity(), "1", "Cart quantity should remain owned by the guest checkout journey");
+    }
+}

