+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.CatalogPage;
+import com.endava.ai.ui.pages.CartPage;
+import com.endava.ai.ui.pages.ContactPage;
+import com.endava.ai.ui.utils.UIActions;
+import org.testng.Assert;
+
+public final class CommerceValidation {
+
+    public void assertUrlContains(String fragment) {
+        Assert.assertTrue(DriverManager.getEngine().getCurrentUrl().contains(fragment),
+                "Expected URL to contain: " + fragment + " but was: " + DriverManager.getEngine().getCurrentUrl());
+    }
+
+    public void assertTextContains(String actual, String expected) {
+        Assert.assertTrue(actual != null && actual.contains(expected),
+                "Expected text to contain: " + expected + " but was: " + actual);
+    }
+
+    public void assertTextNotBlank(String actual, String label) {
+        Assert.assertTrue(actual != null && !actual.trim().isEmpty(), label + " should not be blank");
+    }
+
+    public void assertCurrency(String actual, String label) {
+        Assert.assertTrue(actual != null && actual.trim().matches("\\$\\d+\\.\\d{2}"),
+                label + " should be a visible USD price but was: " + actual);
+    }
+
+    public void assertCatalogHasProducts() {
+        assertTextNotBlank(UIActions.getText(CatalogPage.PRODUCT_NAME, "Catalog product names"), "Catalog product names");
+        assertTextNotBlank(UIActions.getText(CatalogPage.PRODUCT_PRICE, "Catalog product prices"), "Catalog product prices");
+    }
+
+    public void assertCartHasProduct(String expectedName) {
+        assertTextContains(UIActions.getText(CartPage.PRODUCT_TITLE, "Cart title"), expectedName);
+        assertCurrency(UIActions.getText(CartPage.CART_TOTAL, "Cart total"), "Cart total");
+    }
+
+    public void assertGuestIdentityVisible() {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.GUEST_EMAIL), "Guest email should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.GUEST_FIRST_NAME), "Guest first name should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.GUEST_LAST_NAME), "Guest last name should be visible");
+    }
+
+    public void assertPaymentVisible() {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.PAYMENT_METHOD), "Payment method should be visible");
+    }
+
+    public void assertPaymentHidden() {
+        Assert.assertFalse(DriverManager.getEngine().isVisible(CartPage.PAYMENT_METHOD),
+                "Payment method should remain hidden before billing address ownership is completed");
+    }
+
+    public void assertBillingAddressVisible() {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.COUNTRY), "Billing country should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.POSTAL_CODE), "Billing postal code should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.HOUSE_NUMBER), "Billing house number should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.PROCEED_ADDRESS), "Billing proceed should be visible");
+    }
+
+    public void assertBillingAddressNotVisible() {
+        Assert.assertFalse(DriverManager.getEngine().isVisible(CartPage.COUNTRY),
+                "Billing country should remain hidden when guest progression is blocked");
+    }
+
+    public void assertPaymentSuccessVisible() {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(CartPage.PAYMENT_SUCCESS_MESSAGE),
+                "Payment success message should be visible");
+    }
+
+    public void assertVisible(String selector, String label) {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(selector), label + " should be visible");
+    }
+
+    public void assertNotVisible(String selector, String label) {
+        Assert.assertFalse(DriverManager.getEngine().isVisible(selector), label + " should not be visible");
+    }
+
+    public void assertPageTextContains(String pageText, String expected) {
+        Assert.assertTrue(pageText != null && pageText.contains(expected),
+                "Expected page to contain: " + expected + " but page text was: " + pageText);
+    }
+
+    public void assertPageTextDoesNotContain(String pageText, String forbidden) {
+        Assert.assertFalse(pageText != null && pageText.toLowerCase().contains(forbidden.toLowerCase()),
+                "Expected page not to contain: " + forbidden + " but page text was: " + pageText);
+    }
+
+    public void assertContactSurfaceVisible() {
+        Assert.assertTrue(DriverManager.getEngine().isVisible(ContactPage.FIRST_NAME), "Contact first name should be visible");
+        Assert.assertTrue(DriverManager.getEngine().isVisible(ContactPage.SUBJECT), "Contact subject should be visible");
+    }
+}

