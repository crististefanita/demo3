+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.core.DriverManager;
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class CheckoutSuccessValidation {
+
+    private static final String[] COMMERCIAL_IDENTITY_LABELS = {
+            "Order ID",
+            "Order Id",
+            "Order Number",
+            "Order number",
+            "Receipt ID",
+            "Receipt Id",
+            "Receipt Number",
+            "Receipt number",
+            "Invoice Number",
+            "Invoice number",
+            "Reference Number",
+            "Reference number"
+    };
+
+    public void assertPaymentSuccessWithoutCommercialIdentity() {
+        WaitUtils.waitForVisible(CheckoutPage.PAYMENT_SUCCESS_MESSAGE);
+
+        String currentUrl = DriverManager.getEngine().getCurrentUrl();
+        Assert.assertTrue(
+                currentUrl.contains("/checkout"),
+                "Expected checkout success to remain on /checkout, but was: " + currentUrl
+        );
+
+        String body = UIActions.getText(AccountPage.PAGE_BODY, "page body");
+        Assert.assertTrue(
+                body.contains("Payment was successful"),
+                "Expected payment success message to stay visible, but body was: " + body
+        );
+
+        for (String label : COMMERCIAL_IDENTITY_LABELS) {
+            Assert.assertFalse(
+                    body.contains(label),
+                    "Did not expect checkout success body to expose '" + label + "', but body was: " + body
+            );
+        }
+    }
+}
