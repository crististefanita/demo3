+            if (sequence.size() > 1) {
+                return sequence.removeFirst();
+            }
+            return sequence.peekFirst();
+        }
+
+        @Override
+        public String getValue(String cssSelector) {
+            valueCallCounts.merge(cssSelector, 1, Integer::sum);
