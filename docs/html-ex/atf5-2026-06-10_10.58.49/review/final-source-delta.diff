+        public void waitForUrlContains(String fragment, int seconds) {
+            waitedUrlFragment = fragment;
+            waitedUrlSeconds = seconds;
+        }
+
+        @Override
+        public String getCurrentUrl() {
+            return currentUrl;
+        }
+    }
