+                "Expected URL not to contain " + unexpectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
+    }
+
+    public void assertGuestRedirectedToLogin() {
+        String outcome = WaitUtils.waitUntil(
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = DriverManager.getEngine().getText(AccountPage.PAGE_BODY);
+                    boolean loginButtonVisible;
+                    try {
+                        loginButtonVisible = DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON);
+                    } catch (Exception ignored) {
+                        loginButtonVisible = false;
+                    }
+
+                    if ((url != null && url.contains("/auth/login"))
+                            || loginButtonVisible
+                            || body.contains("Sign in with Google")
+                            || body.contains("Not yet an account? Register")) {
+                        return "login-surface";
+                    }
+
+                    return "pending";
+                },
+                value -> !"pending".equals(value),
+                Duration.ofSeconds(20),
+                Duration.ofMillis(250)
+        );
