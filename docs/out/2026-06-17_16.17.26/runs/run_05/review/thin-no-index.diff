+
+    public void assertCurrentUrlDoesNotContain(String unexpectedFragment) {
+        WaitUtils.waitForCondition(
+                "URL does not contain " + unexpectedFragment,
+                () -> !DriverManager.getEngine().getCurrentUrl().contains(unexpectedFragment),
+                "Expected URL not to contain " + unexpectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
