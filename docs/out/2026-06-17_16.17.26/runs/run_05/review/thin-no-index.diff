+        for (String expectedHeader : expectedHeaders) {
+            Assert.assertTrue(
+                    actualHeaders.contains(expectedHeader),
+                    "Expected invoice headers to contain '" + expectedHeader + "' but were: " + actualHeaders
+            );
+        }
+    }
+
+    public void assertVisibleTextsContain(String selector, String description, String expectedText) {
+        WaitUtils.waitForVisible(selector);
