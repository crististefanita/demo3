+
+public final class AccountValidation {
+
+    public void assertCurrentUrlContains(String expectedFragment) {
+        WaitUtils.waitForCondition(
+                "URL contains " + expectedFragment,
+                () -> DriverManager.getEngine().getCurrentUrl().contains(expectedFragment),
+                "Expected URL to contain " + expectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
+        Assert.assertTrue(
+                DriverManager.getEngine().getCurrentUrl().contains(expectedFragment),
+                "Expected URL to contain " + expectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
+    }
+
+    public void assertCurrentUrlDoesNotContain(String unexpectedFragment) {
+        WaitUtils.waitForCondition(
+                "URL does not contain " + unexpectedFragment,
+                () -> !DriverManager.getEngine().getCurrentUrl().contains(unexpectedFragment),
+                "Expected URL not to contain " + unexpectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
+        Assert.assertFalse(
+                DriverManager.getEngine().getCurrentUrl().contains(unexpectedFragment),
+                "Expected URL not to contain " + unexpectedFragment + " but was " + DriverManager.getEngine().getCurrentUrl()
+        );
+    }
+
+    public void assertGuestRedirectedToLogin() {
+        String outcome = WaitUtils.waitUntil(
+                () -> {
+                    String url = DriverManager.getEngine().getCurrentUrl();
+                    String body = DriverManager.getEngine().getText(AccountPage.PAGE_BODY);
+                    boolean loginButtonVisible;
+                    try {
+                        loginButtonVisible = DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON);
+                    } catch (Exception ignored) {
+                        loginButtonVisible = false;
+                    }
+
+                    if ((url != null && url.contains("/auth/login"))
+                            || loginButtonVisible
+                            || body.contains("Sign in with Google")
+                            || body.contains("Not yet an account? Register")) {
+                        return "login-surface";
+                    }
+
+                    return "pending";
+                },
+                value -> !"pending".equals(value),
+                Duration.ofSeconds(20),
+                Duration.ofMillis(250)
+        );
+        Assert.assertEquals(outcome, "login-surface", "Expected guest route to resolve to the login surface.");
+        assertVisible(LoginPage.EMAIL, "login email field");
+    }
+
+    public void assertHeadingEquals(String selector, String expectedHeading) {
+        WaitUtils.waitForVisible(selector);
+        String actual = UIActions.getText(selector, "page heading");
+        Assert.assertEquals(actual.trim(), expectedHeading, "Unexpected heading text.");
+    }
+
+    public void assertBodyContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "body contains " + expectedText,
+                () -> DriverManager.getEngine().getText(AccountPage.PAGE_BODY).contains(expectedText),
+                "Expected body text to contain '" + expectedText + "'."
+        );
+        String body = UIActions.getText(AccountPage.PAGE_BODY, "page body");
