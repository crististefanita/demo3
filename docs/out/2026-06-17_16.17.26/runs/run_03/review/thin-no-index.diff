+        String actualValue = UIActions.getValue(selector, description);
+        Assert.assertEquals(actualValue, expectedValue, "Unexpected value for " + description);
+    }
+
+    public void assertVisible(String selector, String description) {
+        WaitUtils.waitForVisible(selector);
+        Assert.assertTrue(DriverManager.getEngine().isVisible(selector), "Expected " + description + " to be visible.");
+    }
+
+    public void assertAlertContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "alert contains " + expectedText,
+                () -> DriverManager.getEngine().getText(ProfilePage.ALERT).contains(expectedText)
+                        || DriverManager.getEngine().getText(AccountPage.PAGE_BODY).contains(expectedText),
+                "Expected alert/body to contain '" + expectedText + "'."
