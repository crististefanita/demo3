+package com.endava.ai.ui.tests;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.utils.UIActions;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedReceiptIdentityOnSuccessTests extends AuthenticatedCheckoutBaseTest {
+
+    private CustomerData sharedCustomer;
+
+    @BeforeMethod(alwaysRun = true)
+    public void beforeReceiptIdentityOnSuccessMethod() {
+        StepLogger.startStep("Authenticated receipt-identity on-success preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Browser session was cleared before the next receipt-identity on-success check");
+    }
+
+    @Test(description = "After COD purchase success the checkout confirmation stays generic and exposes no order or receipt identity")
+    public void after_cod_purchase_success_the_checkout_confirmation_stays_generic_and_exposes_no_order_or_receipt_identity() {
+        CustomerData customer = sharedCustomer = ensureCustomerSession(sharedCustomer);
+        completeAuthenticatedCashOnDeliveryPurchase(customer);
+        assertPaymentSuccessWithoutCommercialIdentity();
+    }
+
+    @Test(description = "After bank-transfer purchase success the checkout confirmation stays generic and exposes no order or receipt identity")
+    public void after_bank_transfer_purchase_success_the_checkout_confirmation_stays_generic_and_exposes_no_order_or_receipt_identity() {
+        CustomerData customer = sharedCustomer = ensureCustomerSession(sharedCustomer);
+        completeAuthenticatedBankTransferPurchase(customer);
+        assertPaymentSuccessWithoutCommercialIdentity();
+    }
+
+    @Test(description = "After gift-card purchase success the checkout confirmation stays generic and exposes no order or receipt identity")
+    public void after_gift_card_purchase_success_the_checkout_confirmation_stays_generic_and_exposes_no_order_or_receipt_identity() {
+        CustomerData customer = sharedCustomer = ensureCustomerSession(sharedCustomer);
+        completeAuthenticatedGiftCardPurchase(customer);
+        assertPaymentSuccessWithoutCommercialIdentity();
+    }
+
+    @Test(description = "After switched credit-card to gift-card purchase success the checkout confirmation stays generic and exposes no order or receipt identity")
+    public void after_switched_credit_card_to_gift_card_purchase_success_the_checkout_confirmation_stays_generic_and_exposes_no_order_or_receipt_identity() {
+        CustomerData customer = sharedCustomer = ensureCustomerSession(sharedCustomer);
+        completeAuthenticatedSwitchedGiftCardPurchase(customer);
+        assertPaymentSuccessWithoutCommercialIdentity();
+    }
+
+    @Test(description = "After two successful purchases the last checkout confirmation still exposes no order or receipt identity")
+    public void after_two_successful_purchases_the_last_checkout_confirmation_still_exposes_no_order_or_receipt_identity() {
+        CustomerData customer = sharedCustomer = ensureCustomerSession(sharedCustomer);
+        completeTwoSuccessfulPurchases(customer);
+        assertPaymentSuccessWithoutCommercialIdentity();
+    }
+}

