+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.pages.CheckoutPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+
+public final class AuthenticatedCheckoutService {
+
+    public void proceedFromCartToPayment(CustomerData customer) {
+        UIActions.click("button[data-test='proceed-1']", "Proceed to checkout from cart");
+        clickAuthenticatedContinueIfPresent();
+        fillBillingAddress(customer);
+        UIActions.click(CheckoutPage.PROCEED_BILLING, "Proceed to payment");
+        WaitUtils.waitForVisible(CheckoutPage.PAYMENT_METHOD);
+    }
+
+    public void fillBillingAddress(CustomerData customer) {
+        WaitUtils.waitForVisible(CheckoutPage.COUNTRY);
+        UIActions.select(CheckoutPage.COUNTRY, "Billing country", customer.getCountry());
+        UIActions.type(CheckoutPage.POSTAL_CODE, "Billing postal code", customer.getPostalCode());
+        UIActions.type(CheckoutPage.HOUSE_NUMBER, "Billing house number", customer.getHouseNumber());
+        UIActions.type(CheckoutPage.STREET, "Billing street", customer.getStreet());
+        UIActions.type(CheckoutPage.CITY, "Billing city", customer.getCity());
+        UIActions.type(CheckoutPage.STATE, "Billing state", customer.getState());
+    }
+
+    public void selectPaymentMethod(String methodLabel) {
+        UIActions.select(CheckoutPage.PAYMENT_METHOD, "Payment method", methodLabel);
+    }
+
+    public void selectMonthlyInstallments(String installmentsLabel) {
+        UIActions.select(CheckoutPage.MONTHLY_INSTALLMENTS, "Monthly installments", installmentsLabel);
+    }
+
+    public void fillBankTransfer(String bankName, String accountName, String accountNumber) {
+        UIActions.type(CheckoutPage.BANK_NAME, "Bank name", bankName);
+        UIActions.type(CheckoutPage.ACCOUNT_NAME, "Account name", accountName);
+        UIActions.type(CheckoutPage.ACCOUNT_NUMBER, "Account number", accountNumber);
+    }
+
+    public void fillCreditCard(String cardNumber, String expirationDate, String cvv, String cardHolderName) {
+        UIActions.type(CheckoutPage.CREDIT_CARD_NUMBER, "Credit card number", cardNumber);
+        UIActions.type(CheckoutPage.EXPIRATION_DATE, "Expiration date", expirationDate);
+        UIActions.type(CheckoutPage.CVV, "CVV", cvv);
+        UIActions.type(CheckoutPage.CARD_HOLDER_NAME, "Card holder name", cardHolderName);
+    }
+
+    public void fillGiftCard(String giftCardNumber, String validationCode) {
+        UIActions.type(CheckoutPage.GIFT_CARD_NUMBER, "Gift card number", giftCardNumber);
+        UIActions.type(CheckoutPage.VALIDATION_CODE, "Validation code", validationCode);
+    }
+
+    public void confirmSelectedPayment() {
+        UIActions.click(CheckoutPage.FINISH, "Confirm payment");
+        WaitUtils.waitForVisible(CheckoutPage.PAYMENT_SUCCESS_MESSAGE);
+    }
+
+    public void confirmCashOnDelivery() {
+        selectPaymentMethod("Cash on Delivery");
+        confirmSelectedPayment();
+    }
+
+    private void clickAuthenticatedContinueIfPresent() {
+        try {
+            if (com.endava.ai.ui.core.DriverManager.getEngine().isVisible(CheckoutPage.PROCEED_AUTHENTICATED)) {
+                UIActions.click(CheckoutPage.PROCEED_AUTHENTICATED, "Proceed as authenticated user");
+            }
+        } catch (Exception ignored) {
+        }
+    }
+}

