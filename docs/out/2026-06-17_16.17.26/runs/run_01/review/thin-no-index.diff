+package com.endava.ai.ui.service;
+
+import com.endava.ai.ui.model.RegistrationData;
+import com.endava.ai.ui.pages.AccountPage;
+import com.endava.ai.ui.pages.LoginPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import com.endava.ai.ui.validation.RegistrationValidation;
+
+public final class AuthenticationService {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+
+    public RegistrationData registerAndLoginFreshUser() {
+        RegistrationData data = registrationService.registerValidUser();
+        registrationValidation.assertRedirectedToLogin();
+        loginFromCurrentPage(data.email(), data.password());
+        return data;
+    }
+
+    public void openLogin() {
+        UIActions.navigateToRelative("/auth/login");
+        WaitUtils.waitForVisible(LoginPage.EMAIL);
+    }
+
+    public void login(String email, String password) {
+        openLogin();
+        loginFromCurrentPage(email, password);
+    }
+
+    public void loginFromCurrentPage(String email, String password) {
+        UIActions.type(LoginPage.EMAIL, "Email address", email);
+        UIActions.type(LoginPage.PASSWORD, "Password", password);
+        UIActions.click(LoginPage.LOGIN_BUTTON, "Login");
+        WaitUtils.waitForCondition(
+                "authenticated account redirect",
+                () -> {
+                    String url = safeCurrentUrl();
+                    String body = safeBodyText();
+                    return url.contains("/account")
+                            || body.contains("My account")
+                            || body.contains("Here you can manage your profile, favorites and orders.");
+                },
+                "Expected login to redirect to an account surface."
+        );
+    }
+
+    private String safeCurrentUrl() {
+        try {
+            return com.endava.ai.ui.core.DriverManager.getEngine().getCurrentUrl();
+        } catch (Exception ignored) {
+            return "";
+        }
+    }
+
+    private String safeBodyText() {
+        try {
+            return com.endava.ai.ui.core.DriverManager.getEngine().getText(AccountPage.PAGE_BODY);
+        } catch (Exception ignored) {
+            return "";
+        }
+    }
+}

