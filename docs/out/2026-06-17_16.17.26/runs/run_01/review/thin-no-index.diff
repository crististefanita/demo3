+                    boolean loginButtonVisible;
+                    try {
+                        loginButtonVisible = DriverManager.getEngine().isVisible(LoginPage.LOGIN_BUTTON);
+                    } catch (Exception ignored) {
+                        loginButtonVisible = false;
