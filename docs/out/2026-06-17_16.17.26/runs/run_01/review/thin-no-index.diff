+package com.endava.ai.ui.validation;
+
+import com.endava.ai.ui.pages.StorefrontPage;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.utils.WaitUtils;
+import org.testng.Assert;
+
+public final class StorefrontValidation {
+
+    public void assertCartBadgeEquals(String expected) {
+        WaitUtils.waitForVisible(StorefrontPage.CART_QUANTITY);
+        String actual = normalize(UIActions.getText(StorefrontPage.CART_QUANTITY, "cart quantity"));
+        Assert.assertEquals(actual, expected, "Unexpected cart quantity badge.");
+    }
+
+    public void assertCartContainsProduct(String expectedProductName) {
+        WaitUtils.waitForVisible(StorefrontPage.PRODUCT_TITLE);
+        String actual = normalize(UIActions.getText(StorefrontPage.PRODUCT_TITLE, "cart product title"));
+        Assert.assertEquals(actual, normalize(expectedProductName), "Unexpected product on the cart surface.");
+    }
+
+    public void assertCartQuantityValue(String expected) {
+        WaitUtils.waitForVisible(StorefrontPage.PRODUCT_QUANTITY_INPUT);
+        String actual = normalize(UIActions.getValue(StorefrontPage.PRODUCT_QUANTITY_INPUT, "cart product quantity"));
+        Assert.assertEquals(actual, expected, "Unexpected cart line quantity.");
+    }
+
+    private String normalize(String value) {
+        return value == null ? "" : value.replace('\u00A0', ' ').trim();
+    }
+}

