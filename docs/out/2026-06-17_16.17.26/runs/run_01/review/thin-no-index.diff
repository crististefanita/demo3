+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+public class AuthenticatedCommercialEntryTests extends BaseTestUI {
+
+    private final RegistrationService registrationService = new RegistrationService();
+    private final RegistrationValidation registrationValidation = new RegistrationValidation();
+    private final AuthenticationService localAuthenticationService = new AuthenticationService();
+    private final StorefrontService storefrontService = new StorefrontService();
+    private final StorefrontValidation storefrontValidation = new StorefrontValidation();
+    private final InvoiceValidation invoiceValidation = new InvoiceValidation();
+    private final AuthenticatedCheckoutService checkoutService = new AuthenticatedCheckoutService();
+    private final AccountService localAccountService = new AccountService();
+    private final AccountValidation localAccountValidation = new AccountValidation();
+
+    @BeforeMethod(alwaysRun = true)
+    public void beforeCommercialMethod() {
+        StepLogger.startStep("Commercial entry preconditions");
+        com.endava.ai.ui.utils.UIActions.clearSession();
+        StepLogger.pass("Browser session was cleared before the next authenticated commerce check");
+    }
+
+    @Test(description = "Authenticated account overview still explains profile, favorites, and orders scope")
+    public void authenticated_account_overview_explains_profile_favorites_and_orders_scope() {
+        registerAndLoginCustomer();
+        localAccountService.openOverview();
+        localAccountValidation.assertCurrentUrlContains("/account");
+        localAccountValidation.assertBodyContains("Here you can manage your profile, favorites and orders.");
+    }
+
+    @Test(description = "Authenticated invoices route starts empty before any purchase materializes")
+    public void authenticated_invoices_route_starts_empty_before_any_purchase_materializes() {
+        registerAndLoginCustomer();
+        localAccountService.openInvoices();
+        invoiceValidation.assertInvoicesPageVisible();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "Authenticated customer can materialize the first product inside the cart badge")
+    public void authenticated_customer_can_materialize_the_first_product_inside_the_cart_badge() {
+        registerAndLoginCustomer();
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        storefrontService.addCurrentProductToCart();
+        storefrontValidation.assertCartBadgeEquals("1");
+    }
+
+    @Test(description = "Authenticated cart preserves the selected product title and quantity")
+    public void authenticated_cart_preserves_the_selected_product_title_and_quantity() {
+        registerAndLoginCustomer();
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        String productName = storefrontService.readCurrentProductName();
+        storefrontService.addCurrentProductToCart();
+        storefrontService.openCart();
+        storefrontValidation.assertCartContainsProduct(productName);
+        storefrontValidation.assertCartQuantityValue("1");
+    }
+
+    @Test(description = "Authenticated checkout can reach the payment-method surface from the cart")
+    public void authenticated_checkout_can_reach_the_payment_method_surface_from_the_cart() {
+        CustomerData customer = registerAndLoginCustomer();
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        storefrontService.addCurrentProductToCart();
+        storefrontService.openCart();
+        checkoutService.proceedFromCartToPayment(customer);
+        localAccountValidation.assertVisible("select[data-test='payment-method']", "payment method dropdown");
+    }
+
+    private CustomerData registerAndLoginCustomer() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+        localAuthenticationService.login(customer.getEmail(), customer.getPassword());
+        localAccountValidation.assertCurrentUrlContains("/account");
+        return customer;
+    }
+}

