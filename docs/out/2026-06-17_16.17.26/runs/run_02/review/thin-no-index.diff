+    }
+
+    public void assertAlertContains(String expectedText) {
+        WaitUtils.waitForCondition(
+                "alert contains " + expectedText,
+                () -> DriverManager.getEngine().getText(ProfilePage.ALERT).contains(expectedText)
+                        || DriverManager.getEngine().getText(AccountPage.PAGE_BODY).contains(expectedText),
+                "Expected alert/body to contain '" + expectedText + "'."
+        );
+        String body = UIActions.getText(AccountPage.PAGE_BODY, "page body");
+        Assert.assertTrue(body.contains(expectedText), "Expected body to contain '" + expectedText + "' but was: " + body);
+    }
+
+    public void assertSubjectOptionsContain(List<String> expectedOptions) {
+        WaitUtils.waitForVisible(ContactPage.SUBJECT);
+        List<String> actualOptions = UIActions.getTexts(ContactPage.SUBJECT_OPTIONS, "contact subject options");
+        for (String expectedOption : expectedOptions) {
+            Assert.assertTrue(
+                    actualOptions.contains(expectedOption),
+                    "Expected subject options to contain '" + expectedOption + "' but were: " + actualOptions
+            );
+        }
+    }
+
+    public void assertAttachmentControlPresent() {
+        assertVisible(ContactPage.ATTACHMENT, "contact attachment input");
+    }
+
+    public void assertBodyDoesNotContain(String unexpectedText) {
+        WaitUtils.pause(Duration.ofSeconds(1));
+        String body = UIActions.getText(AccountPage.PAGE_BODY, "page body");
+        Assert.assertFalse(
+                body.contains(unexpectedText),
+                "Did not expect body to contain '" + unexpectedText + "' but it did: " + body
+        );
+    }
+}

