+        for (String expectedHeader : expectedHeaders) {
+            Assert.assertTrue(
+                    actualHeaders.contains(expectedHeader),
+                    "Expected invoice headers to contain '" + expectedHeader + "' but were: " + actualHeaders
+            );
+        }
+    }
+
+    public void assertVisibleTextsContain(String selector, String description, String expectedText) {
+        WaitUtils.waitForVisible(selector);
+        List<String> texts = UIActions.getVisibleTexts(selector, description);
+        Assert.assertTrue(
+                texts.stream().anyMatch(text -> text.contains(expectedText)),
+                "Expected " + description + " to contain '" + expectedText + "' but were: " + texts
+        );
+    }
+
+    public void assertVisibleTextsDoNotContain(String selector, String description, String unexpectedText) {
