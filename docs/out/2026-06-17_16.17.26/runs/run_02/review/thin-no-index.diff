+package com.endava.ai.ui.tests;
+
+import com.endava.ai.ui.core.BaseTestUI;
+import com.endava.ai.ui.factory.CustomerDataFactory;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.service.AccountService;
+import com.endava.ai.ui.service.AuthenticatedCheckoutService;
+import com.endava.ai.ui.service.AuthenticationService;
+import com.endava.ai.ui.service.RegistrationService;
+import com.endava.ai.ui.service.StorefrontService;
+import com.endava.ai.ui.validation.AccountValidation;
+import com.endava.ai.ui.validation.CheckoutSuccessValidation;
+import com.endava.ai.ui.validation.RegistrationValidation;
+import com.endava.ai.ui.validation.StorefrontValidation;
+
+abstract class AuthenticatedCheckoutBaseTest extends BaseTestUI {
+
+    private static final String OVERVIEW_SCOPE_TEXT = "Here you can manage your profile, favorites and orders.";
+    private static final String GIFT_CARD_NUMBER = "ABCDEFGH12345678";
+    private static final String GIFT_CARD_VALIDATION_CODE = "W9X2";
+    private static final String SECOND_GIFT_CARD_NUMBER = "ZXCVASDF12345678";
+    private static final String SECOND_GIFT_CARD_VALIDATION_CODE = "Q1W2";
+
+    protected final RegistrationService registrationService = new RegistrationService();
+    protected final RegistrationValidation registrationValidation = new RegistrationValidation();
+    protected final AuthenticationService authenticationService = new AuthenticationService();
+    protected final AccountService accountService = new AccountService();
+    protected final AccountValidation accountValidation = new AccountValidation();
+    protected final CheckoutSuccessValidation checkoutSuccessValidation = new CheckoutSuccessValidation();
+    protected final StorefrontService storefrontService = new StorefrontService();
+    protected final StorefrontValidation storefrontValidation = new StorefrontValidation();
+    protected final AuthenticatedCheckoutService checkoutService = new AuthenticatedCheckoutService();
+
+    protected CustomerData registerAndLoginCustomer() {
+        CustomerData customer = CustomerDataFactory.validCustomer();
+        registrationService.openRegister();
+        registrationService.register(customer);
+        registrationValidation.assertRedirectedToLogin();
+        authenticationService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertCurrentUrlContains("/account");
+        return customer;
+    }
+
+    protected CustomerData ensureCustomerSession(CustomerData existingCustomer) {
+        if (existingCustomer == null) {
+            return registerAndLoginCustomer();
+        }
+
+        authenticationService.login(existingCustomer.getEmail(), existingCustomer.getPassword());
+        accountValidation.assertCurrentUrlContains("/account");
+        return existingCustomer;
+    }
+
+    protected void reachPaymentStep(CustomerData customer) {
+        storefrontService.openHome();
+        storefrontService.openFirstProduct();
+        storefrontService.addCurrentProductToCart();
+        storefrontValidation.assertCartBadgeEquals("1");
+        storefrontService.openCart();
+        checkoutService.proceedFromCartToPayment(customer);
+    }
+
+    protected void completeAuthenticatedBnplPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Buy Now Pay Later");
+        checkoutService.selectMonthlyInstallments("3 Monthly Installments");
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    protected void completeAuthenticatedGiftCardPurchase(CustomerData customer) {
+        completeAuthenticatedGiftCardPurchase(customer, GIFT_CARD_NUMBER, GIFT_CARD_VALIDATION_CODE);
+    }
+
+    protected void completeAuthenticatedGiftCardPurchase(CustomerData customer, String giftCardNumber, String validationCode) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Gift Card");
+        checkoutService.fillGiftCard(giftCardNumber, validationCode);
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    protected void completeAuthenticatedBankTransferPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Bank Transfer");
+        checkoutService.fillBankTransfer("Audit Bank", customer.getFirstName() + " " + customer.getLastName(), "12345678901234");
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    protected void completeAuthenticatedSwitchedGiftCardPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Credit Card");
+        checkoutService.selectPaymentMethod("Gift Card");
+        checkoutService.fillGiftCard(SECOND_GIFT_CARD_NUMBER, SECOND_GIFT_CARD_VALIDATION_CODE);
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    protected void completeAuthenticatedCashOnDeliveryPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.confirmCashOnDelivery();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    protected void relogin(CustomerData customer) {
+        com.endava.ai.ui.utils.UIActions.clearSession();
+        authenticationService.login(customer.getEmail(), customer.getPassword());
+        accountValidation.assertCurrentUrlContains("/account");
+    }
+
+    protected void assertOrdersPromiseWithoutOrdersEntry() {
+        accountService.openOverview();
+        accountValidation.assertBodyContains(OVERVIEW_SCOPE_TEXT);
+        accountValidation.assertVisibleTextsDoNotContain(
+                com.endava.ai.ui.pages.AccountPage.NAV_LINKS,
+                "account navigation links",
+                "My orders"
+        );
+    }
+
+    protected void assertOrdersRouteUnavailable() {
+        accountService.openOrders();
+        accountValidation.assertBodyContains("Practice Black Box Testing & Bug Hunting");
+        accountValidation.assertBodyDoesNotContain("My orders");
+    }
+
+    protected void assertInvoiceHistoryStillEmpty() {
+        accountService.openInvoices();
+        new com.endava.ai.ui.validation.InvoiceValidation().assertInvoicesPageVisible();
+        new com.endava.ai.ui.validation.InvoiceValidation().assertInvoiceRowsAbsent();
+    }
+
+    protected void assertPaymentSuccessWithoutCommercialIdentity() {
+        checkoutSuccessValidation.assertPaymentSuccessWithoutCommercialIdentity();
+    }
+
+    protected void assertCommercialHistoryStillLacksPersistentIdentity() {
+        assertOrdersPromiseWithoutOrdersEntry();
+        assertOrdersRouteUnavailable();
+        assertInvoiceHistoryStillEmpty();
+    }
+
+    protected void assertCommercialHistoryStillLacksPersistentIdentityAfterRelogin(CustomerData customer) {
+        relogin(customer);
+        assertCommercialHistoryStillLacksPersistentIdentity();
+    }
+
+    protected void completeTwoSuccessfulPurchases(CustomerData customer) {
+        completeAuthenticatedCashOnDeliveryPurchase(customer);
+        completeAuthenticatedGiftCardPurchase(customer, SECOND_GIFT_CARD_NUMBER, SECOND_GIFT_CARD_VALIDATION_CODE);
+    }
+
+    protected void completeTwoGiftCardPurchases(CustomerData customer) {
+        completeAuthenticatedGiftCardPurchase(customer);
+        completeAuthenticatedGiftCardPurchase(customer, SECOND_GIFT_CARD_NUMBER, SECOND_GIFT_CARD_VALIDATION_CODE);
+    }
+}

