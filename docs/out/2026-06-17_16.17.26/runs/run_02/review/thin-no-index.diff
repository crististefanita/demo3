+package com.endava.ai.ui.tests;
+
+import com.endava.ai.core.reporting.StepLogger;
+import com.endava.ai.ui.model.CustomerData;
+import com.endava.ai.ui.utils.UIActions;
+import com.endava.ai.ui.validation.InvoiceValidation;
+import org.testng.annotations.BeforeMethod;
+import org.testng.annotations.Test;
+
+import java.util.Arrays;
+
+public class AuthenticatedOrdersPromiseContradictionTests extends AuthenticatedCheckoutBaseTest {
+
+    private final InvoiceValidation invoiceValidation = new InvoiceValidation();
+
+    @BeforeMethod(alwaysRun = true)
+    public void beforeOrdersPromiseMethod() {
+        StepLogger.startStep("Authenticated orders-promise contradiction preconditions");
+        UIActions.clearSession();
+        StepLogger.pass("Browser session was cleared before the next orders-promise contradiction check");
+    }
+
+    @Test(description = "After COD payment success the account overview still promises orders while invoices stay empty")
+    public void after_cod_payment_success_the_account_overview_still_promises_orders_while_invoices_stay_empty() {
+        CustomerData customer = registerAndLoginCustomer();
+        completeCashOnDeliveryPurchase(customer);
+        accountService.openOverview();
+        accountValidation.assertBodyContains("Here you can manage your profile, favorites and orders.");
+        accountService.openInvoices();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "After bank-transfer payment success the orders promise survives a fresh relogin while invoices stay empty")
+    public void after_bank_transfer_payment_success_the_orders_promise_survives_a_fresh_relogin_while_invoices_stay_empty() {
+        CustomerData customer = registerAndLoginCustomer();
+        completeBankTransferPurchase(customer);
+        UIActions.clearSession();
+        authenticationService.login(customer.getEmail(), customer.getPassword());
+        accountService.openOverview();
+        accountValidation.assertBodyContains("Here you can manage your profile, favorites and orders.");
+        accountService.openInvoices();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "After gift-card payment success the invoices table headers still render even when history stays empty")
+    public void after_gift_card_payment_success_the_invoices_table_headers_still_render_even_when_history_stays_empty() {
+        CustomerData customer = registerAndLoginCustomer();
+        completeGiftCardPurchase(customer, "ABCDEFGH12345678", "W9X2");
+        accountService.openInvoices();
+        accountValidation.assertInvoiceHeaders(Arrays.asList("Invoice Number", "Billing Address", "Invoice Date", "Total"));
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "After BNPL payment success the direct invoices route stays empty even before relogin")
+    public void after_bnpl_payment_success_the_direct_invoices_route_stays_empty_even_before_relogin() {
+        CustomerData customer = registerAndLoginCustomer();
+        completeBnplPurchase(customer);
+        accountService.openInvoices();
+        invoiceValidation.assertInvoicesPageVisible();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    @Test(description = "After two successful purchases the account overview still promises orders while invoices remain empty after relogin")
+    public void after_two_successful_purchases_the_account_overview_still_promises_orders_while_invoices_remain_empty_after_relogin() {
+        CustomerData customer = registerAndLoginCustomer();
+        completeCashOnDeliveryPurchase(customer);
+        completeGiftCardPurchase(customer, "ZXCVASDF12345678", "Q1W2");
+        UIActions.clearSession();
+        authenticationService.login(customer.getEmail(), customer.getPassword());
+        accountService.openOverview();
+        accountValidation.assertBodyContains("Here you can manage your profile, favorites and orders.");
+        accountService.openInvoices();
+        invoiceValidation.assertInvoiceRowsAbsent();
+    }
+
+    private void completeBnplPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Buy Now Pay Later");
+        checkoutService.selectMonthlyInstallments("3 Monthly Installments");
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    private void completeGiftCardPurchase(CustomerData customer, String giftCardNumber, String validationCode) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Gift Card");
+        checkoutService.fillGiftCard(giftCardNumber, validationCode);
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    private void completeBankTransferPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.selectPaymentMethod("Bank Transfer");
+        checkoutService.fillBankTransfer("Audit Bank", customer.getFirstName() + " " + customer.getLastName(), "12345678901234");
+        checkoutService.confirmSelectedPayment();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+
+    private void completeCashOnDeliveryPurchase(CustomerData customer) {
+        reachPaymentStep(customer);
+        checkoutService.confirmCashOnDelivery();
+        accountValidation.assertBodyContains("Payment was successful");
+    }
+}

